@model WebHS.ViewModels.AllBookingsViewModel
<link rel="stylesheet" href="/css/host-bookings.css" />
@{
    ViewData["Title"] = "Tất Cả Đặt Phòng";
    Layout = "_Layout_New";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card host-bookings-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0 d-flex align-items-center gap-2">
                        <i class="fas fa-calendar-alt mr-2"></i>
                        Tất Cả Đặt Phòng
                    </h3>
                    <div class="card-tools">
                        <span class="badge badge-info">@Model.TotalBookings đặt phòng</span>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Filters -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <form method="get" class="form-inline">
                                <label class="mr-2">Trạng thái:</label>
                                <select name="status" class="form-control mr-3" onchange="this.form.submit()">
                                    <option value="all" selected="@(Model.CurrentStatus == "all")">Tất cả</option>
                                    <option value="Paid" selected="@(Model.CurrentStatus == "Paid")">Đã thanh toán</option>
                                    <option value="Completed" selected="@(Model.CurrentStatus == "Completed")">Hoàn thành</option>
                                    <option value="Cancelled" selected="@(Model.CurrentStatus == "Cancelled")">Đã hủy</option>
                                </select>
                                
                                <label class="mr-2">Homestay:</label>
                                <select name="homestayFilter" class="form-control" onchange="this.form.submit()">
                                    <option value="">Tất cả homestay</option>
                                    @foreach (var homestay in Model.Homestays)
                                    {
                                        <option value="@homestay.Value" selected="@(Model.HomestayFilter?.ToString() == homestay.Value)">
                                            @homestay.Text
                                        </option>
                                    }
                                </select>
                                <input type="hidden" name="page" value="1" />
                            </form>
                        </div>
                        <div class="col-md-6 text-right">
                            <span class="text-muted">
                                Trang @Model.CurrentPage / @Model.TotalPages
                            </span>
                        </div>
                    </div>

                    <!-- Bookings Table -->
                    @if (Model.Bookings.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover host-bookings-table">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>Mã đặt phòng</th>
                                        <th>Homestay</th>
                                        <th>Khách hàng</th>
                                        <th>Check-in</th>
                                        <th>Check-out</th>
                                        <th>Số khách</th>
                                        <th>Tổng tiền</th>
                                        <th>Trạng thái</th>
                                        <th>Ngày đặt</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in Model.Bookings)
                                    {
                                        <tr>
                                            <td>
                                                <strong>#@booking.Id</strong>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <span>@booking.Homestay?.Name</span>
                                                </div>
                                            </td>
                                            <td>
                                                @booking.User?.FullName
                                                <br><small class="text-muted">@booking.User?.Email</small>
                                            </td>
                                            <td>@booking.CheckInDate.ToString("dd/MM/yyyy")</td>
                                            <td>@booking.CheckOutDate.ToString("dd/MM/yyyy")</td>
                                            <td>

                                                <span class="host-guests-badge"><span>@booking.NumberOfGuests</span> <i class="fas fa-user-friends"></i></span>
                                            </td>
                                            <td>
                                                <strong>@booking.FinalAmount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</strong>
                                            </td>
                                            <td>
                                                @{
                                                    var statusClass = booking.Status switch
                                                    {
                                                        WebHS.Models.BookingStatus.Paid => "success",
                                                        WebHS.Models.BookingStatus.Completed => "primary",
                                                        WebHS.Models.BookingStatus.Cancelled => "danger",
                                                        _ => "secondary"
                                                    };
                                                    var statusText = booking.Status switch
                                                    {
                                                        WebHS.Models.BookingStatus.Paid => "Đã thanh toán",
                                                        WebHS.Models.BookingStatus.Completed => "Hoàn thành",
                                                        WebHS.Models.BookingStatus.Cancelled => "Đã hủy",
                                                        _ => "Không xác định"
                                                    };
                                                }
                                                <span class="booking-badge @statusClass">@statusText</span>
                                            </td>
                                            <td>
                                                @booking.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("BookingDetail", new { id = booking.Id })" 
                                                       class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (booking.Status == WebHS.Models.BookingStatus.Paid)
                                                    {
                                                        <button class="btn btn-sm btn-outline-success" 
                                                                onclick="completeBooking(@booking.Id)" title="Đánh dấu hoàn thành">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <!-- Pagination -->
                        @if (Model.TotalPages > 1)
                        {
                            <nav aria-label="Booking pagination">
                                <ul class="pagination justify-content-center">
                                    @if (Model.CurrentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("AllBookings", new { status = Model.CurrentStatus, page = Model.CurrentPage - 1, homestayFilter = Model.HomestayFilter })">
                                                Trước
                                            </a>
                                        </li>
                                    }
                                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("AllBookings", new { status = Model.CurrentStatus, page = i, homestayFilter = Model.HomestayFilter })">
                                                @i
                                            </a>
                                        </li>
                                    }
                                    @if (Model.CurrentPage < Model.TotalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("AllBookings", new { status = Model.CurrentStatus, page = Model.CurrentPage + 1, homestayFilter = Model.HomestayFilter })">
                                                Sau
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                            <h4 class="text-muted">Không có đặt phòng nào</h4>
                            <p class="text-muted">Các đặt phòng sẽ xuất hiện ở đây khi có khách đặt.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showHostToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} host-toast animate__animated animate__fadeInDown`;
            toast.innerHTML = `
                ${message}
                <button type="button" class="btn-close ms-2" onclick="this.parentElement.remove()"></button>
            `;
            document.body.appendChild(toast);
            setTimeout(() => { if (toast.parentElement) toast.remove(); }, 2000);
        }
        function completeBooking(bookingId) {
            if (confirm('Xác nhận hoàn thành đặt phòng này?')) {
                fetch('@Url.Action("CompleteBooking")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: 'id=' + bookingId
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showHostToast('Đã đánh dấu hoàn thành!', 'success');
                        setTimeout(() => location.reload(), 800);
                    } else {
                        showHostToast('Có lỗi: ' + data.message, 'danger');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showHostToast('Có lỗi xảy ra', 'danger');
                });
            }
        }
    </script>
}
