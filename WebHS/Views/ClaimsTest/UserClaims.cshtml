@model List<dynamic>
@{
    ViewData["Title"] = "Claims của bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h1 class="mb-4">@ViewData["Title"]</h1>
    
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
    
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Loại Claim</th>
                            <th>Giá trị</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var claim in Model)
                        {
                            <tr>
                                <td>@claim.Type</td>
                                <td>@claim.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (!Model.Any())
            {
                <div class="alert alert-info mt-3">
                    <p>Bạn không có claim nào. Vui lòng liên hệ quản trị viên để được cấp quyền.</p>
                </div>
            }
        </div>
    </div>
    
    <div class="card mt-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Thông tin về Claims</h5>
        </div>
        <div class="card-body">
            <p>Claims là các thông tin bổ sung được gán cho tài khoản của bạn, giúp xác định các quyền hạn và thuộc tính đặc biệt.</p>
            <p>Các claim cơ bản như "name", "email" được tạo tự động khi bạn đăng nhập. Các claim quyền hạn và đặc biệt phải được quản trị viên cấp cho bạn.</p>
        </div>
    </div>
</div>
