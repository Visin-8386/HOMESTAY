@{
    ViewData["Title"] = "Xác minh email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body text-center p-5">
                    @if (TempData["Message"] != null)
                    {
                        <!-- Success Icon -->
                        <div class="mb-4">
                            <div class="rounded-circle bg-success bg-gradient d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="fas fa-check fa-2x text-white"></i>
                            </div>
                        </div>
                        
                        <!-- Success Message -->
                        <h2 class="fw-bold text-success mb-3">Email đã được xác minh!</h2>
                        <div class="alert alert-success" role="alert">
                            @TempData["Message"]
                        </div>
                        
                        <!-- Success Actions -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a asp-action="Login" class="btn btn-success btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập ngay
                            </a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-home me-2"></i>Về trang chủ
                            </a>
                        </div>
                    }
                    else if (TempData["Error"] != null)
                    {
                        <!-- Error Icon -->
                        <div class="mb-4">
                            <div class="rounded-circle bg-danger bg-gradient d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="fas fa-times fa-2x text-white"></i>
                            </div>
                        </div>
                        
                        <!-- Error Message -->
                        <h2 class="fw-bold text-danger mb-3">Xác minh thất bại</h2>
                        <div class="alert alert-danger" role="alert">
                            @TempData["Error"]
                        </div>
                        
                        <!-- Error Actions -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a asp-action="Register" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-plus me-2"></i>Đăng ký lại
                            </a>
                            <a asp-action="Login" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                            </a>
                        </div>
                        
                        <!-- Help Section -->
                        <div class="mt-4 p-3 bg-light rounded">
                            <h6 class="fw-bold text-secondary mb-2">
                                <i class="fas fa-question-circle me-2"></i>Cần hỗ trợ?
                            </h6>
                            <p class="text-muted mb-2">
                                Link xác minh có thể đã hết hạn hoặc không hợp lệ.
                            </p>
                            <a href="mailto:support@homestaybooking.vn" class="btn btn-outline-info btn-sm">
                                <i class="fas fa-envelope me-1"></i>Liên hệ hỗ trợ
                            </a>
                        </div>
                    }
                    else
                    {
                        <!-- Default State -->
                        <div class="mb-4">
                            <div class="rounded-circle bg-secondary bg-gradient d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="fas fa-envelope fa-2x text-white"></i>
                            </div>
                        </div>
                        
                        <h2 class="fw-bold text-secondary mb-3">Xác minh email</h2>
                        <p class="text-muted mb-4">
                            Vui lòng sử dụng liên kết từ email để xác minh tài khoản của bạn.
                        </p>
                        
                        <a asp-action="Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt me-2"></i>Về trang đăng nhập
                        </a>
                    }
                </div>
            </div>

            <!-- Additional Info Card -->
            <div class="card border-0 bg-light mt-3">
                <div class="card-body p-3">
                    <div class="row g-3 text-center">
                        <div class="col-md-4">
                            <i class="fas fa-shield-alt text-success mb-2 d-block"></i>
                            <small class="text-muted">
                                <strong>Bảo mật</strong><br>
                                Xác minh email giúp bảo vệ tài khoản
                            </small>
                        </div>
                        <div class="col-md-4">
                            <i class="fas fa-bell text-info mb-2 d-block"></i>
                            <small class="text-muted">
                                <strong>Thông báo</strong><br>
                                Nhận cập nhật quan trọng
                            </small>
                        </div>
                        <div class="col-md-4">
                            <i class="fas fa-unlock text-warning mb-2 d-block"></i>
                            <small class="text-muted">
                                <strong>Truy cập đầy đủ</strong><br>
                                Sử dụng tất cả tính năng
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

