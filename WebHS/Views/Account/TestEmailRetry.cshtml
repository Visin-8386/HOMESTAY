@{
    ViewData["Title"] = "Test Email Retry";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="fas fa-envelope me-2"></i>Test Email Retry System
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <strong>🔧 Email Retry Configuration:</strong><br>
                        • Maximum retry attempts: <strong>3 lần</strong><br>
                        • Delay between retries: <strong>2 giây (tăng dần: 2s, 4s, 6s)</strong><br>
                        • Chỉ retry khi có lỗi kết nối hoặc timeout<br>
                        • Không retry nếu email address không tồn tại
                    </div>

                    <form id="testEmailForm">
                        <div class="mb-3">
                            <label for="testEmail" class="form-label">Email để test (có thể dùng email không tồn tại để test retry):</label>
                            <input type="email" class="form-control" id="testEmail" placeholder="test@example.com" required>
                            <div class="form-text">
                                Để test retry: dùng email không tồn tại như <code>test@nonexistentdomain.com</code>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="testSubject" class="form-label">Subject:</label>
                            <input type="text" class="form-control" id="testSubject" value="Test Email - WebHS System" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="testMessage" class="form-label">Message:</label>
                            <textarea class="form-control" id="testMessage" rows="3" required>Đây là email test từ WebHS system với chức năng retry mới.</textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>Send Test Email
                        </button>
                    </form>
                    
                    <div id="testResult" class="mt-4" style="display: none;">
                        <div class="alert" id="resultAlert">
                            <div id="resultContent"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Email Logs -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-list me-2"></i>Email Sending Logs
                    </h5>
                </div>
                <div class="card-body">
                    <div id="emailLogs">
                        <p class="text-muted">Logs sẽ hiển thị ở đây khi gửi email...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .log-entry {
        padding: 8px 12px;
        margin: 4px 0;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        font-size: 0.9em;
    }
    
    .log-info {
        background-color: #e3f2fd;
        border-left: 4px solid #2196f3;
    }
    
    .log-success {
        background-color: #e8f5e8;
        border-left: 4px solid #4caf50;
    }
    
    .log-warning {
        background-color: #fff3e0;
        border-left: 4px solid #ff9800;
    }
    
    .log-error {
        background-color: #ffebee;
        border-left: 4px solid #f44336;
    }
</style>

<script>
document.getElementById('testEmailForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const email = document.getElementById('testEmail').value;
    const subject = document.getElementById('testSubject').value;
    const message = document.getElementById('testMessage').value;
    
    const resultDiv = document.getElementById('testResult');
    const resultAlert = document.getElementById('resultAlert');
    const resultContent = document.getElementById('resultContent');
    const logsDiv = document.getElementById('emailLogs');
    
    // Clear previous logs
    logsDiv.innerHTML = '<div class="log-entry log-info">🚀 Starting email send process...</div>';
    
    // Show loading
    resultDiv.style.display = 'block';
    resultAlert.className = 'alert alert-info';
    resultContent.innerHTML = `
        <div class="d-flex align-items-center">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <span>Đang gửi email với retry logic... Vui lòng chờ</span>
        </div>
    `;
    
    try {
        const response = await fetch('/Account/SendTestEmailWithRetry', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify({
                email: email,
                subject: subject,
                message: message
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            resultAlert.className = 'alert alert-success';
            resultContent.innerHTML = `
                <h6>✅ Email gửi thành công!</h6>
                <p><strong>Attempts:</strong> ${data.attempts}</p>
                <p><strong>Total time:</strong> ${data.totalTimeMs}ms</p>
                <p><strong>Email:</strong> ${email}</p>
            `;
            
            // Add success log
            logsDiv.innerHTML += `<div class="log-entry log-success">✅ Email sent successfully after ${data.attempts} attempt(s)</div>`;
        } else {
            resultAlert.className = 'alert alert-danger';
            resultContent.innerHTML = `
                <h6>❌ Gửi email thất bại</h6>
                <p><strong>Error:</strong> ${data.error}</p>
                <p><strong>Attempts:</strong> ${data.attempts}</p>
                <p><strong>Total time:</strong> ${data.totalTimeMs}ms</p>
            `;
            
            // Add error logs
            if (data.logs && data.logs.length > 0) {
                data.logs.forEach(log => {
                    const logClass = log.includes('❌') ? 'log-error' : 
                                   log.includes('⏳') ? 'log-warning' : 'log-info';
                    logsDiv.innerHTML += `<div class="log-entry ${logClass}">${log}</div>`;
                });
            }
        }
    } catch (error) {
        resultAlert.className = 'alert alert-danger';
        resultContent.innerHTML = `
            <h6>❌ Lỗi kết nối</h6>
            <p>${error.message}</p>
        `;
        
        logsDiv.innerHTML += `<div class="log-entry log-error">❌ Connection error: ${error.message}</div>`;
    }
});
</script>
