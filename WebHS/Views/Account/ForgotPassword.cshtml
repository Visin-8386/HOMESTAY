@model WebHS.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="rounded-circle bg-warning bg-gradient d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                            <i class="fas fa-key fa-2x text-white"></i>
                        </div>
                        <h2 class="fw-bold text-primary">Quên mật khẩu?</h2>
                        <p class="text-muted">Nhập email để nhận liên kết đặt lại mật khẩu</p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-envelope text-muted"></i>
                                </span>
                                <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="Nhập email của bạn" autofocus>
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-paper-plane me-2"></i>Gửi liên kết đặt lại
                            </button>
                        </div>

                        <div class="text-center">
                            <span class="text-muted">Nhớ lại mật khẩu? </span>
                            <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Security Note -->
            <div class="card border-0 bg-light mt-3">
                <div class="card-body p-3">
                    <div class="d-flex align-items-start">
                        <i class="fas fa-shield-alt text-info me-2 mt-1"></i>
                        <div>
                            <small class="text-muted">
                                <strong>Lưu ý bảo mật:</strong> Chúng tôi sẽ gửi email đến địa chỉ này nếu nó tồn tại trong hệ thống. 
                                Kiểm tra cả hộp thư spam nếu bạn không thấy email trong vài phút.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

