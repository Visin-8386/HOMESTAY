@{
    ViewData["Title"] = "Kiểm tra email của bạn!";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <span class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width:60px;height:60px;font-size:2rem;">
                            <i class="fas fa-envelope-open-text"></i>
                        </span>
                    </div>
                    <h2 class="mb-3 font-weight-bold text-primary">Kiểm tra email của bạn!</h2>
                    <p class="mb-4 text-secondary">Chúng tôi đã gửi một email xác nhận đến địa chỉ email bạn đã đăng ký.<br>Vui lòng kiểm tra hộp thư đến (và cả thư mục spam) và nhấp vào liên kết xác nhận để kích hoạt tài khoản.</p>
                    <div class="row mb-4">
                        <div class="col-4">
                            <div class="step-circle">1</div>
                            <div class="step-label">Mở email</div>
                        </div>
                        <div class="col-4">
                            <div class="step-circle">2</div>
                            <div class="step-label">Nhấp liên kết</div>
                        </div>
                        <div class="col-4">
                            <div class="step-circle">3</div>
                            <div class="step-label">Đăng nhập</div>
                        </div>
                    </div>
                    <div class="alert alert-warning mb-4" role="alert">
                        <i class="fas fa-exclamation-triangle mr-2"></i>Liên kết xác nhận sẽ hết hạn sau 24 giờ
                    </div>
                    <a href="https://mail.google.com" target="_blank" class="btn btn-primary btn-lg mb-2 w-100">
                        <i class="fas fa-external-link-alt mr-2"></i> Mở ứng dụng email
                    </a>
                    <a href="@Url.Action("Register")" class="btn btn-link d-block mb-2">Trở về đăng ký</a>
                    <div class="mt-3">
                        <span class="text-muted">Không nhận được email?</span>
                        <a href="javascript:void(0)" onclick="location.reload()">Kiểm tra spam</a> |
                        <a href="@Url.Action("ResendConfirmationEmail")">Gửi lại email</a> |
                        <a href="@Url.Action("Support")">Liên hệ hỗ trợ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .step-circle {
        width: 40px;
        height: 40px;
        background: #007bff;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px auto;
        font-weight: bold;
        font-size: 1.2rem;
    }
    .step-label {
        font-size: 0.95rem;
        color: #333;
        text-align: center;
    }
</style>

