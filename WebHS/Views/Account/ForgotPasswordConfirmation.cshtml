@{
    ViewData["Title"] = "Xác nhận gửi email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body text-center p-5">
                    <!-- Success Icon -->
                    <div class="mb-4">
                        <div class="rounded-circle bg-success bg-gradient d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-check fa-2x text-white"></i>
                        </div>
                    </div>
                    
                    <!-- Title -->
                    <h2 class="fw-bold text-success mb-3">Email đã được gửi!</h2>
                    
                    <!-- Message -->
                    <div class="mb-4">
                        <p class="text-muted mb-3">
                            Nếu địa chỉ email bạn nhập tồn tại trong hệ thống, chúng tôi đã gửi email chứa liên kết đặt lại mật khẩu.
                        </p>
                        <p class="text-muted mb-3">
                            Vui lòng kiểm tra hộp thư đến (và cả thư mục spam) của bạn.
                        </p>
                    </div>
                    
                    <!-- Info Box -->
                    <div class="bg-light rounded p-4 mb-4">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-clock text-warning me-2"></i>
                                    <small class="text-muted">Hết hạn sau 24 giờ</small>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-shield-alt text-success me-2"></i>
                                    <small class="text-muted">Bảo mật và an toàn</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Actions -->
                    <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                        <a asp-action="Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt me-2"></i>Quay lại đăng nhập
                        </a>
                        <a asp-action="ForgotPassword" class="btn btn-outline-secondary">
                            <i class="fas fa-redo me-2"></i>Gửi lại email
                        </a>
                    </div>
                </div>
            </div>

            <!-- Help Section -->
            <div class="card border-0 bg-light mt-3">
                <div class="card-body p-3">
                    <div class="text-center">
                        <small class="text-muted">
                            <i class="fas fa-question-circle me-1"></i>
                            Không nhận được email? Kiểm tra thư mục spam hoặc 
                            <a href="mailto:support@homestaybooking.vn" class="text-primary">liên hệ hỗ trợ</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

