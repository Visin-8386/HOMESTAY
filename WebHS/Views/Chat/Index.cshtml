</style>
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Chat AI Enhanced v3.0 - Ready!'); 
            
            const chatMessages = $('#chat-messages');
            const chatInput = $('#chat-input');
            const sendBtn = $('#send-btn');
            let messageCount = 0;
            let soundEnabled = true;
            
            // Initialize page
            initializePage();
            
            function initializePage() {
                // Remove welcome message after 3 seconds
                setTimeout(() => {
                    $('.welcome-message').fadeOut(500);
                }, 3000);
                
                // Bind events
                bindEvents();
                
                // Auto-focus input
                if (chatInput.length) {
                    chatInput.focus();
                }
                
                // Load chat history if available
                loadChatHistory();
                
                // Clean any existing injected content
                cleanInjectedContent();
                
                // Set up periodic cleaning every 30 seconds
                setInterval(cleanInjectedContent, 30000);
            }
            
            
            function bindEvents() {
                // Send button click
                sendBtn.on('click', sendMessage);
                
                // Enter key press
                chatInput.on('keypress', function(e) {
                    if (e.which === 13 && !e.shiftKey) {
                        e.preventDefault();
                        sendMessage();
                    }
                });
                
                // Quick action buttons
                $('.quick-action-btn').on('click', function() {
                    const message = $(this).data('message');
                    if (message) {
                        chatInput.val(message);
                        sendMessage();
                    }
                });
                
                // Clear chat button
                $('#clearChat').on('click', function() {
                    if (confirm('Bạn có chắc muốn xóa toàn bộ lịch sử chat?')) {
                        clearChatHistory();
                        showToast('Đã xóa lịch sử chat');
                    }
                });
                
                // Toggle sound button
                $('#toggleSound').on('click', function() {
                    soundEnabled = !soundEnabled;
                    const icon = $(this).find('i');
                    if (soundEnabled) {
                        icon.removeClass('fa-volume-mute').addClass('fa-volume-up');
                        playSound('toggle');
                    } else {
                        icon.removeClass('fa-volume-up').addClass('fa-volume-mute');
                    }
                    showToast(soundEnabled ? 'Âm thanh đã bật' : 'Âm thanh đã tắt');
                    localStorage.setItem('soundEnabled', soundEnabled);
                });
                
                // Input focus effects
                chatInput.on('focus', function() {
                    $('.chat-input-container').addClass('focused');
                }).on('blur', function() {
                    $('.chat-input-container').removeClass('focused');
                });
                
                // Typing animation
                chatInput.on('input', function() {
                    if ($(this).val().length > 0) {
                        $('.input-wrapper').addClass('typing');
                        sendBtn.removeClass('disabled');
                    } else {
                        $('.input-wrapper').removeClass('typing');
                        sendBtn.addClass('disabled');
                    }
                });
                
                // Enhanced interactive effects
                initializeEnhancedEffects();
            }
            
            
            // Enhanced Interactive Effects
            function initializeEnhancedEffects() {
                // Floating particles
                createFloatingParticles();
                
                // Message hover effects
                $(document).on('mouseenter', '.message-content', function() {
                    createMessageRipple(this);
                });
                
                // Send button enhanced effects
                sendBtn.on('mouseenter', function() {
                    createHoverGlow(this);
                });
            }
            
            // Create floating particles
            function createFloatingParticles() {
                const container = $('.chat-container')[0];
                if (!container) return;
                
                setInterval(() => {
                    for (let i = 0; i < 3; i++) {
                        setTimeout(() => {
                            const particle = document.createElement('div');
                            particle.className = 'particle';
                            particle.style.left = Math.random() * 100 + '%';
                            particle.style.animationDuration = (Math.random() * 4 + 3) + 's';
                            particle.style.animationDelay = Math.random() * 2 + 's';
                            container.appendChild(particle);
                            
                            setTimeout(() => {
                                if (particle.parentNode) {
                                    particle.parentNode.removeChild(particle);
                                }
                            }, 7000);
                        }, i * 500);
                    }
                }, 3000);
            }
            
            // Create message ripple effect
            function createMessageRipple(element) {
                const ripple = document.createElement('div');
                ripple.className = 'message-ripple';
                ripple.style.position = 'absolute';
                ripple.style.borderRadius = '50%';
                ripple.style.background = 'rgba(102,126,234,0.2)';
                ripple.style.transform = 'scale(0)';
                ripple.style.animation = 'messageRipple 0.8s ease-out';
                ripple.style.pointerEvents = 'none';
                ripple.style.zIndex = '1';
                
                const rect = element.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height) * 1.5;
                ripple.style.width = ripple.style.height = size + 'px';
                ripple.style.left = (rect.width / 2 - size / 2) + 'px';
                ripple.style.top = (rect.height / 2 - size / 2) + 'px';
                
                element.style.position = 'relative';
                element.style.overflow = 'hidden';
                element.appendChild(ripple);
                
                setTimeout(() => {
                    if (ripple.parentNode) {
                        ripple.parentNode.removeChild(ripple);
                    }
                }, 800);
            }
            
            // Create hover glow effect
            function createHoverGlow(element) {
                const glow = document.createElement('div');
                glow.className = 'hover-glow';
                glow.style.position = 'absolute';
                glow.style.top = '-10px';
                glow.style.left = '-10px';
                glow.style.right = '-10px';
                glow.style.bottom = '-10px';
                glow.style.borderRadius = '50%';
                glow.style.background = 'radial-gradient(circle, rgba(102,126,234,0.3) 0%, transparent 70%)';
                glow.style.pointerEvents = 'none';
                glow.style.animation = 'hoverGlow 0.5s ease-out';
                glow.style.zIndex = '-1';
                
                element.style.position = 'relative';
                element.appendChild(glow);
                
                setTimeout(() => {
                    if (glow.parentNode) {
                        glow.parentNode.removeChild(glow);
                    }
                }, 500);
            }
            
            // Show toast notification
            function showToast(message) {
                const toast = $(`
                    <div class="toast-notification">
                        <i class="fas fa-check-circle me-2"></i>
                        ${message}
                    </div>
                `);
                
                $('body').append(toast);
                
                setTimeout(() => {
                    toast.addClass('show');
                }, 100);
                
                setTimeout(() => {
                    toast.removeClass('show');
                    setTimeout(() => {
                        toast.remove();
                    }, 300);
                }, 2000);
            }
            
            // Clear chat history
            function clearChatHistory() {
                localStorage.removeItem('chatHistory');
                $('.message').not('#initial-message').remove();
                $('.welcome-message').show();
                messageCount = 0;
            }
            
            // Play sound effect
            function playSound(type) {
                if (!soundEnabled) return;
                
                try {
                    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                    const frequencies = {
                        send: [800, 1000],
                        receive: [600, 800],
                        clear: [400, 200],
                        toggle: [1000, 500],
                        enable: [1200, 800]
                    };
                    
                    const [freq1, freq2] = frequencies[type] || [500, 500];
                    
                    // Create oscillator for sound effect
                    const oscillator = audioContext.createOscillator();
                    const gainNode = audioContext.createGain();
                    
                    oscillator.connect(gainNode);
                    gainNode.connect(audioContext.destination);
                    
                    oscillator.frequency.setValueAtTime(freq1, audioContext.currentTime);
                    oscillator.frequency.exponentialRampToValueAtTime(freq2, audioContext.currentTime + 0.1);
                    
                    gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
                    
                    oscillator.start(audioContext.currentTime);
                    oscillator.stop(audioContext.currentTime + 0.1);
                } catch (e) {
                    console.log('Audio not supported');
                }
            }
            
            // Play sound effect
            function playSound(type) {
                if (!soundEnabled) return;
                
                try {
                    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                    const frequencies = {
                        send: [800, 1000],
                        receive: [600, 800],
                        clear: [400, 200],
                        toggle: [1000, 500]
                    };
                    
                    const [freq1, freq2] = frequencies[type] || [500, 500];
                    
                    // Create oscillator for sound effect
                    const oscillator = audioContext.createOscillator();
                    const gainNode = audioContext.createGain();
                    
                    oscillator.connect(gainNode);
                    gainNode.connect(audioContext.destination);
                    
                    oscillator.frequency.setValueAtTime(freq1, audioContext.currentTime);
                    oscillator.frequency.exponentialRampToValueAtTime(freq2, audioContext.currentTime + 0.1);
                    
                    gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
                    
                    oscillator.start(audioContext.currentTime);
                    oscillator.stop(audioContext.currentTime + 0.1);
                } catch (e) {
                    console.log('Audio not supported');
                }
            }
            
            
            // Auto-scroll to bottom with smooth animation
            function scrollToBottom() {
                if (chatMessages.length) {
                    chatMessages.animate({
                        scrollTop: chatMessages[0].scrollHeight
                    }, 300);
                }
            }
            
            // Show typing indicator
            function showTyping() {
                const typingHtml = '<div class="typing-indicator" id="typing-indicator">' +
                    '<div class="message-avatar"><i class="fas fa-robot"></i></div>' +
                    '<div class="typing-content">' +
                        '<div class="typing-text">' +
                            '<div class="typing-dots">' +
                                '<span></span>' +
                                '<span></span>' +
                                '<span></span>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
                chatMessages.append(typingHtml);
                $('.typing-indicator').show();
                scrollToBottom();
            }
            
            // Hide typing indicator
            function hideTyping() {
                $('#typing-indicator').remove();
            }
            
            // Enhanced add message function
            function addMessage(content, isUser = false, delay = 0) {
                setTimeout(() => {
                    const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                    const messageClass = isUser ? 'user-message' : 'bot-message';
                    const avatar = isUser ? '<i class="fas fa-user"></i>' : '<i class="fas fa-robot"></i>';
                    
                    // Convert URLs to clickable links and add emojis - with sanitization
                    const enhancedContent = enhanceContent(content);
                    
                    messageCount++;
                    const messageHtml = '<div class="message ' + messageClass + '" style="animation-delay: ' + delay + 'ms">' +
                        '<div class="message-avatar">' + avatar + '</div>' +
                        '<div class="message-content">' +
                            '<div class="message-text">' + enhancedContent + '</div>' +
                            '<div class="message-time">' + timestamp + '</div>' +
                        '</div>' +
                    '</div>';
                    
                    chatMessages.append(messageHtml);
                    scrollToBottom();
                    
                    // Clean any unwanted content that might have been added
                    cleanInjectedContent();
                    
                    // Play sound
                    playSound(isUser ? 'send' : 'receive');
                    
                    // Save to local storage
                    saveChatHistory();
                    
                }, delay);
            }
            
            
            // Sanitize message content to prevent HTML injection and remove unwanted JSON/CSS/JS
            function sanitizeMessage(text) {
                if (typeof text !== 'string') {
                    return 'Phản hồi không hợp lệ';
                }
                
                // Remove any HTML tags
                text = text.replace(/<[^>]*>/g, '');
                
                // Remove potential JSON fragments
                text = text.replace(/\{[^}]*\}/g, '');
                text = text.replace(/\[[^\]]*\]/g, '');
                
                // Remove CSS/JS like patterns
                text = text.replace(/[.#][a-zA-Z-_]+\s*\{[^}]*\}/g, '');
                text = text.replace(/function\s*\([^)]*\)\s*\{[^}]*\}/g, '');
                
                // Remove script-like content
                text = text.replace(/<script[^>]*>.*?<\/script>/gi, '');
                text = text.replace(/<style[^>]*>.*?<\/style>/gi, '');
                
                return text.trim() || 'Phản hồi trống';
            }
            
            // Clean any injected content from the DOM
            function cleanInjectedContent() {
                // Remove any suspicious CSS classes or IDs that might have been injected
                $('[class*="messaging-"], [id*="messaging-"]').remove();
                
                // Remove any script tags that might have been injected
                $('script:not([src])').each(function() {
                    if ($(this).text().includes('messaging') || $(this).text().includes('websocket')) {
                        $(this).remove();
                    }
                });
                
                // Clean up any unwanted CSS that might have leaked
                $('style').each(function() {
                    const styleContent = $(this).text();
                    if (styleContent.includes('.messaging-') || styleContent.includes('#messaging-')) {
                        $(this).remove();
                    }
                });
                // Không xóa các phần tử .message-text, .bot-message, .user-message nữa để tránh mất khung chữ
                // Không xóa JSON hoặc text có từ khóa CSS trong nội dung chat
            }
            
            // Enhanced content processing
            function enhanceContent(text) {
                // First sanitize the content
                text = sanitizeMessage(text);
                
                // Then apply URL linking
                let enhanced = linkifyText(text);
                
                return enhanced;
            }
            
            // Convert URLs in text to clickable links
            function linkifyText(text) {
                const urlRegex = /(https?:\/\/[^\s<>"{}|\\^`\[\]]+)/g;
                return text.replace(urlRegex, function(url) {
                    let cleanUrl = url;
                    let trailingPunctuation = '';
                    
                    const punctuationRegex = /([.,:;!?])$/;
                    const match = cleanUrl.match(punctuationRegex);
                    if (match) {
                        trailingPunctuation = match[1];
                        cleanUrl = cleanUrl.slice(0, -1);
                    }
                    
                    return '<a href="' + cleanUrl + '" target="_blank" class="homestay-link">🔗 Xem chi tiết</a>' + trailingPunctuation;
                });
            }


            
            // Save chat history to localStorage
            function saveChatHistory() {
                const messages = [];
                $('.message').each(function() {
                    const isUser = $(this).hasClass('user-message');
                    const content = $(this).find('.message-text').text();
                    const time = $(this).find('.message-time').text();
                    messages.push({ content, isUser, time });
                });
                localStorage.setItem('chatHistory', JSON.stringify(messages));
            }
            
            // Load chat history from localStorage
            function loadChatHistory() {
                const history = localStorage.getItem('chatHistory');
                if (history) {
                    try {
                        const messages = JSON.parse(history);
                        // Only show last 10 messages to avoid clutter
                        const recentMessages = messages.slice(-10);
                        
                        recentMessages.forEach((msg, index) => {
                            if (msg.content) {
                                setTimeout(() => {
                                    addMessage(msg.content, msg.isUser, 0);
                                }, index * 100);
                            }
                        });
                    } catch (e) {
                        console.error('Error loading chat history:', e);
                    }
                }
                
                // Load sound preference
                const soundPref = localStorage.getItem('soundEnabled');
                if (soundPref !== null) {
                    soundEnabled = soundPref === 'true';
                    const icon = soundEnabled ? 'fa-volume-up' : 'fa-volume-mute';
                    $('#toggleSound i').removeClass('fa-volume-up fa-volume-mute').addClass(icon);
                }
            }
            
            // Show typing indicator
            function showTyping() {
                const typingHtml = '<div class="typing-indicator" id="typing-indicator">' +
                    '<div class="message-avatar"><i class="fas fa-robot"></i></div>' +
                    '<div class="typing-content">' +
                        '<div class="typing-text">' +
                            '<div class="typing-dots">' +
                                '<span></span>' +
                                '<span></span>' +
                                '<span></span>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
                chatMessages.append(typingHtml);
                $('.typing-indicator').show();
                scrollToBottom();
            }
            
            // Hide typing indicator
            function hideTyping() {
                $('#typing-indicator').remove();
            }
            
            // Auto-scroll to bottom with smooth animation
            function scrollToBottom() {
                if (chatMessages.length) {
                    chatMessages.animate({
                        scrollTop: chatMessages[0].scrollHeight
                    }, 300);
                }
            }
            
            // Send message function
            async function sendMessage() {
                const message = chatInput.val().trim();
                if (!message) return;
                
                // Add user message
                addMessage(message, true);
                chatInput.val('');
                
                // Disable send button and show typing
                sendBtn.prop('disabled', true);
                showTyping();
                
                try {
                    console.log('Sending message:', message);
                    const response = await fetch('/Chat/SendMessage', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        body: JSON.stringify({ Message: message })
                    });
                    
                    console.log('Response status:', response.status);
                    
                    if (!response.ok) {
                        throw new Error('HTTP error! status: ' + response.status);
                    }
                    
                    const contentType = response.headers.get('content-type');
                    if (!contentType || !contentType.includes('application/json')) {
                        throw new Error('Server returned non-JSON response');
                    }
                    
                    const responseText = await response.text();
                    console.log('Raw response text:', responseText);
                    
                    // Validate that we have valid JSON
                    let data;
                    try {
                        data = JSON.parse(responseText);
                    } catch (parseError) {
                        console.error('Failed to parse JSON:', parseError);
                        throw new Error('Invalid JSON response from server');
                    }
                    
                    console.log('Parsed response data:', data);
                    hideTyping();
                    
                    // Check for both uppercase and lowercase property names to handle different response formats
                    const isSuccess = data.Success || data.success;
                    const responseMessage = data.Response || data.response;
                    const errorMessage = data.Error || data.error;
                    
                    if (isSuccess) {
                        console.log('Success! Adding message:', responseMessage);
                        // Validate and sanitize the response message
                        const sanitizedMessage = sanitizeMessage(responseMessage || 'Không có phản hồi từ AI');
                        addMessage(sanitizedMessage);
                    } else {
                        console.log('Error response:', errorMessage);
                        const sanitizedError = sanitizeMessage(errorMessage || 'Lỗi không xác định');
                        addMessage('Xin lỗi, có lỗi xảy ra: ' + sanitizedError);
                    }
                } catch (error) {
                    hideTyping();
                    addMessage('Xin lỗi, không thể kết nối đến server. Vui lòng thử lại.');
                    console.error('Chat error:', error);
                } finally {
                    sendBtn.prop('disabled', false);
                    if (chatInput.length) {
                        chatInput.focus();
                    }
                    
                    // Always clean the page after any server interaction
                    setTimeout(cleanInjectedContent, 500);
                }
            }
            
            // Auto-greetings based on time
            const hour = new Date().getHours();
            let greeting = '';
            if (hour < 12) greeting = '🌅 Chào buổi sáng!';
            else if (hour < 18) greeting = '☀️ Chào buổi chiều!';
            else greeting = '🌙 Chào buổi tối!';
            
            // Update typing status
            $('.typing-status').text(greeting + ' • Sẵn sàng trò chuyện');
            
            // Initial focus
            if (chatInput.length) {
                chatInput.focus();
            }
            scrollToBottom();
        });
    </script>
}
