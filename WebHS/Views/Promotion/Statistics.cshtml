@model WebHS.ViewModels.PromotionStatisticsViewModel
@{
    ViewData["Title"] = "Thống kê khuyến mãi";
}

<div class="promotion-statistics">
    <div class="container-fluid mt-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="page-header">
                    <h1 class="page-title">
                        <i class="fas fa-chart-pie me-3"></i>Thống kê khuyến mãi
                    </h1>
                    <div class="page-actions">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                        </a>
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>Tạo khuyến mãi mới
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stat-card bg-primary text-white">
                    <div class="stat-card-body">
                        <div class="stat-icon">
                            <i class="fas fa-tags"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number">@Model.TotalPromotions</div>
                            <div class="stat-label">Tổng khuyến mãi</div>
                        </div>
                    </div>
                    <div class="stat-footer">
                        <span>Tất cả khuyến mãi trong hệ thống</span>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stat-card bg-success text-white">
                    <div class="stat-card-body">
                        <div class="stat-icon">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number">@Model.ActivePromotions</div>
                            <div class="stat-label">Đang hoạt động</div>
                        </div>
                    </div>
                    <div class="stat-footer">
                        <span>Khuyến mãi có hiệu lực hiện tại</span>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stat-card bg-info text-white">
                    <div class="stat-card-body">
                        <div class="stat-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number">@Model.TotalUsage.ToString("N0")</div>
                            <div class="stat-label">Lượt sử dụng</div>
                        </div>
                    </div>
                    <div class="stat-footer">
                        <span>Tổng số lần khuyến mãi được áp dụng</span>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stat-card bg-warning text-white">
                    <div class="stat-card-body">
                        <div class="stat-icon">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number">@Model.TotalDiscount.ToString("N0")</div>
                            <div class="stat-label">Tổng giảm giá (VNĐ)</div>
                        </div>
                    </div>
                    <div class="stat-footer">
                        <span>Tổng tiền đã giảm cho khách hàng</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Promotions Chart -->
        <div class="row">
            <div class="col-12">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-trophy me-2"></i>Top 10 khuyến mãi được sử dụng nhiều nhất
                        </h5>
                    </div>
                    <div class="chart-body">
                        @if (Model.TopPromotions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Tên khuyến mãi</th>
                                            <th>Mã code</th>
                                            <th>Lượt sử dụng</th>
                                            <th>Tổng giảm giá</th>
                                            <th>Hiệu suất</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (promotion, index) in Model.TopPromotions.Select((p, i) => (p, i + 1)))
                                        {
                                            <tr>
                                                <td>
                                                    <span class="rank-badge rank-@(index <= 3 ? "top" : "normal")">
                                                        @index
                                                    </span>
                                                </td>
                                                <td>
                                                    <div class="promotion-name">@promotion.Name</div>
                                                </td>
                                                <td>
                                                    <code class="promotion-code">@promotion.Code</code>
                                                </td>
                                                <td>
                                                    <span class="usage-count">@promotion.UsedCount</span>
                                                </td>
                                                <td>
                                                    <span class="discount-amount">@promotion.TotalDiscount.ToString("N0") VNĐ</span>
                                                </td>
                                                <td>
                                                    <div class="performance-bar">
                                                        <div class="progress">
                                                            <div class="progress-bar bg-success" 
                                                                 style="width: @(Model.TopPromotions.Any() ? (double)promotion.UsedCount / Model.TopPromotions.Max(p => p.UsedCount) * 100 : 0)%">
                                                            </div>
                                                        </div>
                                                        <small class="performance-text">
                                                            @((Model.TopPromotions.Any() ? (double)promotion.UsedCount / Model.TopPromotions.Max(p => p.UsedCount) * 100 : 0).ToString("F1"))%
                                                        </small>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <div class="empty-icon">
                                    <i class="fas fa-chart-bar"></i>
                                </div>
                                <h5>Chưa có dữ liệu thống kê</h5>
                                <p class="text-muted">Chưa có khuyến mãi nào được sử dụng</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus me-2"></i>Tạo khuyến mãi đầu tiên
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .promotion-statistics {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
        padding: 20px 0;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding: 25px;
        background: linear-gradient(145deg, #ffffff, #f8f9fa);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .page-title {
        color: #2d3748;
        font-weight: 700;
        margin: 0;
        font-size: 2rem;
    }

    .page-actions {
        display: flex;
        gap: 10px;
    }

    .stat-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    .stat-card-body {
        padding: 25px;
        display: flex;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .stat-icon {
        font-size: 3rem;
        opacity: 0.3;
        margin-right: 20px;
    }

    .stat-content {
        flex: 1;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 5px;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .stat-label {
        font-size: 1.1rem;
        font-weight: 500;
        opacity: 0.9;
    }

    .stat-footer {
        padding: 15px 25px;
        background: rgba(0,0,0,0.1);
        font-size: 0.9rem;
        opacity: 0.8;
    }

    .chart-card {
        background: linear-gradient(145deg, #ffffff, #f8f9fa);
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .chart-header {
        padding: 25px;
        border-bottom: 1px solid rgba(0,0,0,0.1);
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .chart-title {
        margin: 0;
        font-weight: 600;
        text-shadow: 0 2px 4px rgba(0,0,0,0.2);
    }

    .chart-body {
        padding: 25px;
    }

    .table {
        margin: 0;
    }

    .table thead th {
        border: none;
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        color: #495057;
        font-weight: 600;
        padding: 15px;
    }

    .table tbody tr {
        transition: all 0.3s ease;
    }

    .table tbody tr:hover {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
        transform: scale(1.01);
    }

    .table tbody td {
        padding: 15px;
        border: none;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        vertical-align: middle;
    }

    .rank-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        font-weight: 700;
        color: white;
        font-size: 0.9rem;
    }

    .rank-badge.rank-top {
        background: linear-gradient(135deg, #ffd700, #ff8c00);
        box-shadow: 0 3px 10px rgba(255, 215, 0, 0.4);
    }

    .rank-badge.rank-normal {
        background: linear-gradient(135deg, #6c757d, #495057);
    }

    .promotion-name {
        font-weight: 600;
        color: #2d3748;
    }

    .promotion-code {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .usage-count {
        font-weight: 700;
        color: #38a169;
        font-size: 1.1rem;
    }

    .discount-amount {
        font-weight: 700;
        color: #e53e3e;
        font-size: 1.1rem;
    }

    .performance-bar {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .progress {
        flex: 1;
        height: 8px;
        border-radius: 10px;
        background: #e2e8f0;
        overflow: hidden;
    }

    .progress-bar {
        transition: width 1s ease;
        border-radius: 10px;
    }

    .performance-text {
        font-weight: 600;
        color: #4a5568;
        min-width: 45px;
        text-align: right;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.3;
    }

    .empty-state h5 {
        margin-bottom: 10px;
        color: #4a5568;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            text-align: center;
            gap: 20px;
        }

        .page-actions {
            flex-direction: column;
            width: 100%;
        }

        .stat-card-body {
            flex-direction: column;
            text-align: center;
        }

        .stat-icon {
            margin-right: 0;
            margin-bottom: 15px;
        }

        .table-responsive {
            border-radius: 10px;
        }
    }
</style>

<script>
    $(document).ready(function() {
        // Initialize animations
        $('.stat-card').each(function(index) {
            $(this).css({
                'opacity': '0',
                'transform': 'translateY(30px)'
            }).delay(index * 100).animate({
                'opacity': '1'
            }, 600, function() {
                $(this).css('transform', 'translateY(0)');
            });
        });

        // Animate progress bars
        setTimeout(function() {
            $('.progress-bar').each(function() {
                const width = $(this).css('width');
                $(this).css('width', '0').animate({
                    'width': width
                }, 1000);
            });
        }, 500);

        // Add hover effects to table rows
        $('.table tbody tr').hover(
            function() {
                $(this).find('.rank-badge').addClass('animated pulse');
            },
            function() {
                $(this).find('.rank-badge').removeClass('animated pulse');
            }
        );
    });
</script>
