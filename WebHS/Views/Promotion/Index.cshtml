@using WebHSPromotionType = WebHS.Models.PromotionType
@model WebHS.ViewModels.PromotionListViewModel

@{
    ViewData["Title"] = "Quản Lý Khuyến Mãi";
    Layout = "_Layout_New";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-promotion.css" asp-append-version="true" />
    <style>
        /* Enhanced Promotion Management Styles */
        .promotion-dashboard {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: calc(100vh - 120px);
            padding: 2rem 0;
            position: relative;
            overflow: hidden;
        }

        .promotion-dashboard::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: rotate-bg 20s linear infinite;
            pointer-events: none;
        }

        @@keyframes rotate-bg {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .page-header-promotion {
            background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.9) 100%);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            position: relative;
            overflow: hidden;
        }

        .page-header-promotion::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, #ff6b6b, #feca57, #48dbfb, #ff9ff3);
            animation: rainbow-slide 3s ease-in-out infinite;
        }

        @@keyframes rainbow-slide {
            0%, 100% { transform: translateX(-100%); }
            50% { transform: translateX(100%); }
        }

        .promotion-stats {
            margin-bottom: 2rem;
        }

        .promotion-stat-card {
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            border: none;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .promotion-stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--card-color);
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }

        .promotion-stat-card:hover::before {
            transform: scaleX(1);
        }

        .promotion-stat-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

        .stat-icon-promotion {
            font-size: 3rem;
            margin-bottom: 1rem;
            transition: transform 0.3s ease;
        }

        .promotion-stat-card:hover .stat-icon-promotion {
            transform: scale(1.2) rotate(5deg);
        }

        .stat-number-promotion {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            counter-reset: number var(--number);
        }

        .stat-label-promotion {
            color: #6c757d;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .main-promotion-card {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            overflow: hidden;
            animation: slide-up 0.6s ease-out;
        }

        @@keyframes slide-up {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card-header-promotion {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-bottom: 2px solid #dee2e6;
            padding: 2rem;
            border-radius: 20px 20px 0 0 !important;
            position: relative;
        }

        .filter-card-promotion {
            background: rgba(255,255,255,0.9);
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            backdrop-filter: blur(10px);
        }

        .search-box-promotion {
            position: relative;
            overflow: hidden;
        }

        .search-box-promotion input {
            border-radius: 25px;
            border: 2px solid #e9ecef;
            padding: 0.75rem 1.5rem 0.75rem 3rem;
            background: rgba(255,255,255,0.9);
            transition: all 0.3s ease;
            backdrop-filter: blur(5px);
        }

        .search-box-promotion input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
            transform: scale(1.02);
            background: rgba(255,255,255,1);
        }

        .search-box-promotion::before {
            content: '\f002';
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            z-index: 2;
        }

        .btn-promotion {
            border-radius: 25px;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            border: none;
            position: relative;
            overflow: hidden;
        }

        .btn-promotion::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .btn-promotion:hover::before {
            left: 100%;
        }

        .btn-promotion:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .btn-primary-promotion {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-success-promotion {
            background: linear-gradient(135deg, #56ab2f 0%, #a8e6cf 100%);
            color: white;
        }

        .btn-warning-promotion {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }

        .btn-danger-promotion {
            background: linear-gradient(135deg, #fc466b 0%, #3f5efb 100%);
            color: white;
        }

        .btn-info-promotion {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
        }

        .filter-dropdown-promotion .dropdown-menu {
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border: none;
            padding: 0.5rem 0;
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.95);
        }

        .filter-dropdown-promotion .dropdown-item {
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
        }

        .filter-dropdown-promotion .dropdown-item:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateX(5px);
        }

        .promotion-code-advanced {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-weight: 700;
            font-family: 'Courier New', monospace;
            letter-spacing: 1px;
            display: inline-block;
            position: relative;
            overflow: hidden;
        }

        .promotion-code-advanced::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: code-shine 2s infinite;
        }

        @@keyframes code-shine {
            0% { left: -100%; }
            100% { left: 100%; }
        }

        .badge-promotion-advanced {
            border-radius: 20px;
            padding: 0.5rem 1rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 0.75rem;
            position: relative;
            overflow: hidden;
        }

        .badge-promotion-advanced::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.3) 50%, transparent 70%);
            transform: translateX(-100%);
            transition: transform 0.6s;
        }

        .badge-promotion-advanced:hover::before {
            transform: translateX(100%);
        }

        .badge-percentage-advanced {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
        }

        .badge-fixed-advanced {
            background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            color: white;
        }

        .badge-active-advanced {
            background: linear-gradient(135deg, #56ab2f 0%, #a8e6cf 100%);
            color: white;
            animation: pulse-active 2s infinite;
        }

        .badge-upcoming-advanced {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
        }

        .badge-expired-advanced {
            background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
            color: white;
        }

        .badge-inactive-advanced {
            background: linear-gradient(135deg, #fc466b 0%, #3f5efb 100%);
            color: white;
        }

        @@keyframes pulse-active {
            0%, 100% { box-shadow: 0 0 0 0 rgba(86, 171, 47, 0.4); }
            50% { box-shadow: 0 0 0 8px rgba(86, 171, 47, 0); }
        }

        .pagination-promotion-advanced {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            margin-top: 2rem;
        }

        .page-link-promotion {
            border-radius: 10px;
            margin: 0 0.25rem;
            border: 2px solid transparent;
            transition: all 0.3s ease;
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(5px);
            padding: 0.75rem 1rem;
            text-decoration: none;
            color: #495057;
            font-weight: 600;
        }

        .page-link-promotion:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .page-item-promotion.active .page-link-promotion {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .promotion-value {
            font-size: 1.25rem;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .promotion-dashboard {
                padding: 1rem 0;
            }
            
            .page-header-promotion {
                padding: 1rem;
                margin-bottom: 1rem;
            }
            
            .promotion-stat-card {
                margin-bottom: 1rem;
            }
            
            .table-responsive {
                font-size: 0.9rem;
            }
        }

        /* Dark mode support */
        @@media (prefers-color-scheme: dark) {
            .promotion-dashboard {
                background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            }
            
            .main-promotion-card,
            .promotion-stat-card,
            .filter-card-promotion {
                background: rgba(45, 55, 72, 0.9);
                color: #e2e8f0;
            }
        }
    </style>
}

@Html.AntiForgeryToken()

<div class="promotion-dashboard">
    <div class="container-fluid">
        <!-- Page Header -->
        <div class="page-header-promotion text-center">
            <h1 class="mb-3">
                <i class="fas fa-tags me-3" style="color: #667eea;"></i>
                Quản Lý Khuyến Mãi
            </h1>
            <p class="lead mb-0">Tạo và quản lý các chương trình khuyến mãi hiệu quả</p>
        </div>

        <!-- Statistics Cards -->
        <div class="promotion-stats">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="promotion-stat-card text-center" style="--card-color: #667eea; --number: @Model.Promotions.Count()">
                        <div class="stat-icon-promotion" style="color: #667eea;">
                            <i class="fas fa-tags"></i>
                        </div>
                        <div class="stat-number-promotion" style="color: #667eea;">@Model.Promotions.Count()</div>
                        <div class="stat-label-promotion">Tổng Khuyến Mãi</div>
                    </div>
                </div>                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="promotion-stat-card text-center" style="--card-color: #56ab2f;">
                        <div class="stat-icon-promotion" style="color: #56ab2f;">
                            <i class="fas fa-play-circle"></i>
                        </div>
                        <div class="stat-number-promotion" style="color: #56ab2f;">@Model.Promotions.Count(p => p.StatusText == "Đang hoạt động")</div>
                        <div class="stat-label-promotion">Đang Hoạt Động</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="promotion-stat-card text-center" style="--card-color: #4facfe;">
                        <div class="stat-icon-promotion" style="color: #4facfe;">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="stat-number-promotion" style="color: #4facfe;">@Model.Promotions.Count(p => p.StatusText == "Sắp diễn ra")</div>
                        <div class="stat-label-promotion">Sắp Diễn Ra</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="promotion-stat-card text-center" style="--card-color: #fc466b; --number: @Model.Promotions.Sum(p => p.UsedCount)">
                        <div class="stat-icon-promotion" style="color: #fc466b;">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="stat-number-promotion" style="color: #fc466b;">@Model.Promotions.Sum(p => p.UsedCount)</div>
                        <div class="stat-label-promotion">Lượt Sử Dụng</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Card -->
        <div class="main-promotion-card">
            <div class="card-header-promotion">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h3 class="mb-0">
                            <i class="fas fa-list-alt me-2"></i>Danh Sách Khuyến Mãi
                        </h3>
                    </div>
                    <div class="col-md-6 text-end">
                        <a href="@Url.Action("Create")" class="btn btn-primary-promotion btn-promotion">
                            <i class="fas fa-plus me-2"></i>Tạo Khuyến Mãi
                        </a>
                    </div>
                </div>
            </div>            <!-- Controls Section -->
            <div class="filter-card-promotion">
                <div class="row align-items-center">
                    <div class="col-lg-4 mb-3 mb-lg-0">
                        <div class="search-box-promotion">
                            <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm khuyến mãi..." value="@ViewBag.Search">
                        </div>
                    </div>
                    <div class="col-lg-3 mb-3 mb-lg-0">
                        <div class="filter-dropdown-promotion dropdown">
                            <button class="btn btn-warning-promotion btn-promotion dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-filter me-2"></i>Loại: @(ViewBag.Type ?? "Tất cả")
                            </button>
                            <ul class="dropdown-menu w-100">
                                <li><a class="dropdown-item" href="?type=&status=@ViewBag.Status&search=@ViewBag.Search">
                                    <i class="fas fa-list me-2"></i>Tất cả
                                </a></li>
                                <li><a class="dropdown-item" href="?type=percentage&status=@ViewBag.Status&search=@ViewBag.Search">
                                    <i class="fas fa-percentage me-2"></i>Phần trăm
                                </a></li>
                                <li><a class="dropdown-item" href="?type=fixed&status=@ViewBag.Status&search=@ViewBag.Search">
                                    <i class="fas fa-dollar-sign me-2"></i>Số tiền cố định
                                </a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-3 mb-3 mb-lg-0">
                        <div class="filter-dropdown-promotion dropdown">
                            <button class="btn btn-info-promotion btn-promotion dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-chart-bar me-2"></i>Trạng thái: @(ViewBag.Status ?? "Tất cả")
                            </button>
                            <ul class="dropdown-menu w-100">
                                <li><a class="dropdown-item" href="?status=&type=@ViewBag.Type&search=@ViewBag.Search">
                                    <i class="fas fa-list me-2"></i>Tất cả
                                </a></li>
                                <li><a class="dropdown-item" href="?status=active&type=@ViewBag.Type&search=@ViewBag.Search">
                                    <i class="fas fa-play me-2"></i>Đang hoạt động
                                </a></li>
                                <li><a class="dropdown-item" href="?status=upcoming&type=@ViewBag.Type&search=@ViewBag.Search">
                                    <i class="fas fa-clock me-2"></i>Sắp diễn ra
                                </a></li>
                                <li><a class="dropdown-item" href="?status=expired&type=@ViewBag.Type&search=@ViewBag.Search">
                                    <i class="fas fa-calendar-times me-2"></i>Đã hết hạn
                                </a></li>
                                <li><a class="dropdown-item" href="?status=inactive&type=@ViewBag.Type&search=@ViewBag.Search">
                                    <i class="fas fa-ban me-2"></i>Tạm ngưng
                                </a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-2">
                        <button type="button" class="btn btn-success-promotion btn-promotion w-100" onclick="performSearch()">
                            <i class="fas fa-search me-2"></i>Tìm
                        </button>
                    </div>
                </div>
            </div>                <div class="card-body table-responsive p-0">
                    <table class="table table-promotion-advanced table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Tên khuyến mãi</th>
                                <th>Loại</th>
                                <th>Giá trị</th>
                                <th>Thời gian</th>
                                <th>Sử dụng</th>
                                <th>Trạng thái</th>
                                <th class="action-column">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var promotion in Model.Promotions)
                            {
                                <tr>
                                    <td><span class="promotion-code-advanced">@promotion.Code</span></td>
                                    <td>
                                        <strong>@promotion.Name</strong>
                                        @if(!string.IsNullOrEmpty(promotion.Description))
                                        {
                                            <br><small class="text-muted">@promotion.Description</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-promotion-advanced @(promotion.Type == WebHSPromotionType.Percentage ? "badge-percentage-advanced" : "badge-fixed-advanced")">
                                            @promotion.TypeText
                                        </span>
                                    </td>
                                    <td>
                                        <div class="promotion-value">
                                            @if(promotion.Type == WebHSPromotionType.Percentage)
                                            {
                                                @($"{promotion.Value:0.##}%")
                                            }
                                            else
                                            {
                                                @promotion.Value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))
                                            }
                                        </div>
                                        @if(promotion.MinOrderAmount.HasValue)
                                        {
                                            <br><small class="text-muted">Tối thiểu: @promotion.MinOrderAmount.Value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</small>
                                        }
                                        @if(promotion.MaxDiscountAmount.HasValue)
                                        {
                                            <br><small class="text-muted">Tối đa: @promotion.MaxDiscountAmount.Value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</small>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            <strong>Từ:</strong> @promotion.StartDate.ToString("dd/MM/yyyy")<br>
                                            <strong>Đến:</strong> @promotion.EndDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <strong>@promotion.UsedCount</strong>
                                        @if(promotion.UsageLimit.HasValue)
                                        {
                                            <span>/@promotion.UsageLimit.Value</span>
                                        }
                                        else
                                        {
                                            <span>/∞</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var badgeClass = promotion.StatusText switch
                                            {
                                                "Đang hoạt động" => "badge-active-advanced",
                                                "Sắp diễn ra" => "badge-upcoming-advanced",
                                                "Đã hết hạn" => "badge-expired-advanced",
                                                "Đã hết lượt" => "badge-expired-advanced",
                                                "Tạm ngưng" => "badge-inactive-advanced",
                                                _ => "badge-expired-advanced"
                                            };
                                        }
                                        <span class="badge badge-promotion-advanced @badgeClass">@promotion.StatusText</span>
                                    </td>
                                    <td>
                                        <div class="action-group-promotion">
                                            <a href="@Url.Action("Edit", new { id = promotion.Id })" class="action-btn-promotion-advanced btn-edit-promotion" title="Chỉnh sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            
                                            <button type="button" class="action-btn-promotion-advanced btn-toggle-promotion" 
                                                    onclick="toggleStatus(@promotion.Id, @promotion.IsActive.ToString().ToLower())"
                                                    title="@(promotion.IsActive ? "Tạm ngưng" : "Kích hoạt")">
                                                <i class="fas @(promotion.IsActive ? "fa-pause" : "fa-play")"></i>
                                            </button>
                                            
                                            <button type="button" class="action-btn-promotion-advanced btn-delete-promotion" 
                                                    onclick="deletePromotion(@promotion.Id)" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>                @if(Model.TotalPages > 1)
                {
                    <div class="card-footer clearfix">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="dataTables_info">
                                    Hiển thị @((Model.CurrentPage - 1) * 20 + 1) đến @(Math.Min(Model.CurrentPage * 20, Model.TotalCount)) 
                                    trong tổng số @Model.TotalCount khuyến mãi
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="pagination-promotion-advanced">
                                    @if(Model.CurrentPage > 1)
                                    {
                                        <a class="page-link-promotion" href="?page=@(Model.CurrentPage - 1)&status=@ViewBag.Status">
                                            <i class="fas fa-chevron-left"></i>
                                        </a>
                                    }

                                    @for(int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                    {
                                        <a class="page-link-promotion @(i == Model.CurrentPage ? "page-item-promotion active" : "")" href="?page=@i&status=@ViewBag.Status">@i</a>
                                    }

                                    @if(Model.CurrentPage < Model.TotalPages)
                                    {
                                        <a class="page-link-promotion" href="?page=@(Model.CurrentPage + 1)&status=@ViewBag.Status">
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-promotion.js" asp-append-version="true"></script>
    <script>
        // Set global URL for create promotion (used by FAB)
        window.createPromotionUrl = '@Url.Action("Create")';
        
        // Initialize any additional functionality here if needed
        document.addEventListener('DOMContentLoaded', function() {
            // Add any page-specific initialization
        });
    </script>
}



