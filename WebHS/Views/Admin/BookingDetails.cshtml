@using WebHS.Models
@using WebHSPromotionType = WebHS.Models.PromotionType
@using WebHSBookingStatus = WebHS.Models.BookingStatus
@model WebHS.Models.Booking

@{
    ViewData["Title"] = "Chi tiết đặt phòng";
    Layout = "_Layout_New";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Chi tiết đặt phòng #@Model.Id.ToString("D6")</h2>
                <a asp-action="Bookings" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                </a>
            </div>

            <div class="row">
                <!-- Left Column - Booking Details -->
                <div class="col-lg-8">
                    <!-- Booking Info -->
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-calendar-check me-2"></i>Thông tin đặt phòng
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td class="fw-bold">Mã đặt phòng:</td>
                                            <td>#@Model.Id.ToString("D6")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Trạng thái:</td>
                                            <td>
                                                @{
                                                    var statusClass = Model.Status switch
                                                    {
                                                        BookingStatus.Paid => "Đã thanh toán",
                                                        BookingStatus.Completed => "bg-info",
                                                        BookingStatus.Cancelled => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                    var statusText = Model.Status switch
                                                    {
                                                        BookingStatus.Paid => "Đã thanh toán",
                                                        BookingStatus.Completed => "Đã trả phòng",
                                                        BookingStatus.Cancelled => "Đã hủy",
                                                        _ => "Không xác định"
                                                    };
                                                }
                                                <span class="badge @statusClass fs-6">@statusText</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Ngày đặt:</td>
                                            <td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Số khách:</td>
                                            <td>@Model.NumberOfGuests người</td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td class="fw-bold">Ngày nhận phòng:</td>
                                            <td>@Model.CheckInDate.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Ngày trả phòng:</td>
                                            <td>@Model.CheckOutDate.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Số đêm:</td>
                                            <td>@((Model.CheckOutDate - Model.CheckInDate).Days) đêm</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Cập nhật lần cuối:</td>
                                            <td>@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div class="mt-3">
                                    <strong>Ghi chú:</strong>
                                    <p>@Model.Notes</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Customer Info -->
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-user me-2"></i>Thông tin khách hàng
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td class="fw-bold">Họ tên:</td>
                                            <td>@Model.User.FirstName @Model.User.LastName</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Email:</td>
                                            <td>@Model.User.Email</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Số điện thoại:</td>
                                            <td>@(Model.User.PhoneNumber ?? "Chưa cập nhật")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Địa chỉ:</td>
                                            <td>@(Model.User.Address ?? "Chưa cập nhật")</td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-4 text-center">
                                    @if (!string.IsNullOrEmpty(Model.User.ProfilePicture))
                                    {
                                        <img src="@Model.User.ProfilePicture" class="rounded-circle" width="100" height="100" alt="Avatar">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                            <i class="fas fa-user fa-2x text-white"></i>
                                        </div>
                                    }
                                    <div class="mt-2">
                                        <a href="@Url.Action("UserDetail", new { id = Model.UserId })" class="btn btn-sm btn-outline-primary">
                                            Xem chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Homestay Info -->
                    <div class="card mb-4">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-home me-2"></i>Thông tin Homestay
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    @if (Model.Homestay.Images.Any())
                                    {
                                        <img src="@Model.Homestay.Images.First().ImageUrl" class="img-fluid rounded" alt="@Model.Homestay.Name">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 200px;">
                                            <i class="fas fa-home fa-3x text-muted"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-8">
                                    <h5>@Model.Homestay.Name</h5>
                                    <p class="text-muted mb-2">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        @Model.Homestay.Address, @Model.Homestay.City, @Model.Homestay.State
                                    </p>
                                    <p class="mb-2">
                                        <i class="fas fa-user me-1"></i>
                                        <strong>Chủ nhà:</strong> @Model.Homestay.Host.FirstName @Model.Homestay.Host.LastName
                                    </p>
                                    <p class="mb-2">
                                        <i class="fas fa-envelope me-1"></i>
                                        @Model.Homestay.Host.Email
                                    </p>
                                    <p class="mb-0">
                                        <i class="fas fa-phone me-1"></i>
                                        @(Model.Homestay.Host.PhoneNumber ?? "Chưa cập nhật")
                                    </p>
                                    <div class="mt-2">
                                        <a href="@Url.Action("HomestayDetails", new { id = Model.HomestayId })" class="btn btn-sm btn-outline-primary me-2">
                                            Xem chi tiết homestay
                                        </a>
                                        <a href="@Url.Action("UserDetail", new { id = Model.Homestay.HostId })" class="btn btn-sm btn-outline-info">
                                            Xem chi tiết chủ nhà
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Payment & Actions -->
                <div class="col-lg-4">
                    <!-- Payment Info -->
                    <div class="card mb-4 position-sticky" style="top: 20px;">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0">
                                <i class="fas fa-money-bill-wave me-2"></i>Chi tiết thanh toán
                            </h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-borderless">
                                <tr>
                                    <td>Tổng tiền ban đầu:</td>
                                    <td class="text-end">@Model.TotalAmount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</td>
                                </tr>
                                @if (Model.DiscountAmount > 0)
                                {
                                    <tr>
                                        <td>Giảm giá:</td>
                                        <td class="text-end text-success">-@Model.DiscountAmount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</td>
                                    </tr>
                                    @if (Model.PromotionId.HasValue)
                                    {
                                        <tr>
                                            <td colspan="2">
                                                <small class="text-muted">Áp dụng khuyến mãi</small>
                                            </td>
                                        </tr>
                                    }
                                }
                                <tr class="table-active">
                                    <td><strong>Thành tiền:</strong></td>
                                    <td class="text-end"><strong>@Model.FinalAmount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="fas fa-cogs me-2"></i>Thao tác quản lý
                            </h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Status == BookingStatus.Paid)
                            {
                                <button type="button" class="btn btn-success w-100 mb-2" onclick="confirmBooking(@Model.Id)">
                                    <i class="fas fa-check me-2"></i>Xác nhận
                                </button>
                                <button type="button" class="btn btn-danger w-100 mb-2" onclick="cancelBooking(@Model.Id)">
                                    <i class="fas fa-times me-2"></i>Hủy bỏ
                                </button>
                            }
                            else if (Model.Status == BookingStatus.Paid && Model.CheckInDate <= DateTime.Today)
                            {
                                <button type="button" class="btn btn-primary w-100 mb-2" onclick="checkInBooking(@Model.Id)">
                                    <i class="fas fa-sign-in-alt me-2"></i>Nhận phòng
                                </button>
                            }
                            else if (Model.Status == BookingStatus.Paid && Model.CheckOutDate <= DateTime.Today)
                            {
                                <button type="button" class="btn btn-info w-100 mb-2" onclick="checkOutBooking(@Model.Id)">
                                    <i class="fas fa-sign-out-alt me-2"></i>Trả phòng
                                </button>
                            }

                            <a href="@Url.Action("Bookings", new { search = Model.User.Email })" class="btn btn-outline-secondary w-100 mb-2">
                                <i class="fas fa-list me-2"></i>Xem đặt phòng khác của khách
                            </a>

                            <a href="@Url.Action("Bookings", new { search = Model.Homestay.Name })" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-calendar-alt me-2"></i>Xem đặt phòng của homestay
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmBooking(id) {
            if (confirm('Bạn có chắc chắn muốn xác nhận đặt phòng này?')) {
                $.post('@Url.Action("ConfirmBooking")', { bookingId: id }, function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                });
            }
        }

        function cancelBooking(id) {
            if (confirm('Bạn có chắc chắn muốn hủy đặt phòng này?')) {
                $.post('@Url.Action("CancelBooking")', { bookingId: id }, function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                });
            }
        }

        function checkInBooking(id) {
            if (confirm('Xác nhận khách hàng đã nhận phòng?')) {
                // This would need to be implemented in the controller
                alert('Chức năng này cần được thêm vào controller');
            }
        }

        function checkOutBooking(id) {
            if (confirm('Xác nhận khách hàng đã trả phòng?')) {
                // This would need to be implemented in the controller
                alert('Chức năng này cần được thêm vào controller');
            }
        }
    </script>
}

