@using WebHSPromotionType = WebHS.Models.PromotionType
@model WebHS.ViewModels.HomestayDetailViewModel

@{
    ViewData["Title"] = "Chi tiết Homestay";
    Layout = "_Layout_New";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Chi tiết Homestay: @Model.Homestay.Name</h2>
                <a asp-action="Homestays" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                </a>
            </div>

            <div class="row">
                <!-- Left Column - Homestay Info -->
                <div class="col-lg-8">
                    <!-- Images -->
                    @if (Model.Images.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5><i class="fas fa-images me-2"></i>Hình ảnh</h5>
                            </div>
                            <div class="card-body">
                                <div id="homestayCarousel" class="carousel slide" data-bs-ride="carousel">
                                    <div class="carousel-inner">
                                        @for (int i = 0; i < Model.Images.Count; i++)
                                        {
                                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                                <img src="@Model.Images[i].ImageUrl" class="d-block w-100" alt="@Model.Homestay.Name" style="height: 400px; object-fit: cover;">
                                            </div>
                                        }
                                    </div>
                                    @if (Model.Images.Count > 1)
                                    {
                                        <button class="carousel-control-prev" type="button" data-bs-target="#homestayCarousel" data-bs-slide="prev">
                                            <span class="carousel-control-prev-icon"></span>
                                        </button>
                                        <button class="carousel-control-next" type="button" data-bs-target="#homestayCarousel" data-bs-slide="next">
                                            <span class="carousel-control-next-icon"></span>
                                        </button>
                                    }                                </div>
                            </div>
                        </div>
                    }

                    <!-- YouTube Video Section -->
                    @if (!string.IsNullOrEmpty(Model.Homestay.YouTubeVideoId))
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5><i class="fab fa-youtube text-danger me-2"></i>Video giới thiệu</h5>
                            </div>
                            <div class="card-body">
                                <div class="ratio ratio-16x9">
                                    <iframe src="https://www.youtube.com/embed/@Model.Homestay.YouTubeVideoId?rel=0&modestbranding=1" 
                                            title="Video giới thiệu homestay" 
                                            allowfullscreen
                                            class="rounded">
                                    </iframe>
                                </div>
                                <div class="mt-2">
                                    <small class="text-muted">
                                        <strong>Video ID:</strong> @Model.Homestay.YouTubeVideoId
                                        | <a href="https://www.youtube.com/watch?v=@Model.Homestay.YouTubeVideoId" target="_blank">Xem trên YouTube</a>
                                    </small>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Basic Information -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5><i class="fas fa-info-circle me-2"></i>Thông tin cơ bản</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td class="fw-bold">ID:</td>
                                            <td>@Model.Homestay.Id</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Tên:</td>
                                            <td>@Model.Homestay.Name</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Chủ nhà:</td>
                                            <td>@Model.HostName (@Model.HostEmail)</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Giá/đêm:</td>
                                            <td>@Model.Homestay.PricePerNight.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Số khách tối đa:</td>
                                            <td>@Model.Homestay.MaxGuests người</td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td class="fw-bold">Phòng ngủ:</td>
                                            <td>@Model.Homestay.Bedrooms</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Phòng tắm:</td>
                                            <td>@Model.Homestay.Bathrooms</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Trạng thái:</td>
                                            <td>
                                                @if(Model.Homestay.IsApproved && Model.Homestay.IsActive)
                                                {
                                                    <span class="badge bg-success">Đã duyệt</span>
                                                }
                                                else if(!Model.Homestay.IsApproved && Model.Homestay.IsActive)
                                                {
                                                    <span class="badge bg-warning">Chờ duyệt</span>
                                                }
                                                else if(!Model.Homestay.IsActive)
                                                {
                                                    <span class="badge bg-secondary">Không hoạt động</span>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Ngày tạo:</td>
                                            <td>@Model.Homestay.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Đánh giá:</td>
                                            <td>
                                                @if(Model.AverageRating > 0)
                                                {
                                                    @for(int i = 1; i <= 5; i++)
                                                    {
                                                        <i class="fas fa-star @(i <= Model.AverageRating ? "text-warning" : "text-muted")"></i>
                                                    }
                                                    <span>(@Model.ReviewCount đánh giá)</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Chưa có đánh giá</span>
                                                }
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Address -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5><i class="fas fa-map-marker-alt me-2"></i>Địa chỉ</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Địa chỉ đầy đủ:</strong> @Model.Homestay.Address, @Model.Homestay.Ward, @Model.Homestay.District, @Model.Homestay.City, @Model.Homestay.State, @Model.Homestay.Country</p>
                            @if(!string.IsNullOrEmpty(Model.Homestay.ZipCode))
                            {
                                <p><strong>Mã bưu điện:</strong> @Model.Homestay.ZipCode</p>
                            }
                            @if(Model.Homestay.Latitude != 0 && Model.Homestay.Longitude != 0)
                            {
                                <p><strong>Tọa độ:</strong> @Model.Homestay.Latitude, @Model.Homestay.Longitude</p>
                            }
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5><i class="fas fa-align-left me-2"></i>Mô tả</h5>
                        </div>
                        <div class="card-body">
                            <p>@Model.Homestay.Description</p>
                        </div>
                    </div>

                    <!-- Amenities -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5><i class="fas fa-concierge-bell me-2"></i>Tiện nghi</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Amenities.Any())
                            {
                                <div class="row">
                                    @foreach (var amenity in Model.Amenities)
                                    {
                                        <div class="col-md-6 mb-2">
                                            <i class="fas fa-check text-success me-2"></i>@amenity.Name
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Chưa có thông tin tiện nghi</p>
                            }
                        </div>
                    </div>

                    <!-- Rules -->
                    @if (!string.IsNullOrEmpty(Model.Homestay.Rules))
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5><i class="fas fa-list-ul me-2"></i>Nội quy</h5>
                            </div>
                            <div class="card-body">
                                <p>@Model.Homestay.Rules</p>
                            </div>
                        </div>
                    }

                    <!-- Reviews -->
                    @if (Model.ReviewBookings.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5><i class="fas fa-star me-2"></i>Đánh giá (@Model.ReviewCount)</h5>
                            </div>
                            <div class="card-body">
                                @foreach (var booking in Model.ReviewBookings.Take(5))
                                {
                                    <div class="border-bottom mb-3 pb-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h6 class="mb-1">@booking.User.FirstName @booking.User.LastName</h6>
                                                <div class="text-warning">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        <i class="fas fa-star @(i <= booking.ReviewRating ? "" : "text-muted")"></i>
                                                    }
                                                </div>
                                            </div>
                                            <small class="text-muted">@booking.ReviewCreatedAt?.ToString("dd/MM/yyyy")</small>
                                        </div>
                                        <p class="mb-0">@booking.ReviewComment</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Right Column - Actions -->
                <div class="col-lg-4">
                    <div class="card position-sticky" style="top: 20px;">
                        <div class="card-header">
                            <h5><i class="fas fa-cogs me-2"></i>Thao tác quản lý</h5>
                        </div>
                        <div class="card-body">
                            @if(!Model.Homestay.IsApproved && Model.Homestay.IsActive)
                            {
                                <button type="button" class="btn btn-success w-100 mb-2" onclick="approveHomestay(@Model.Homestay.Id)">
                                    <i class="fas fa-check me-2"></i>Phê duyệt
                                </button>
                                <button type="button" class="btn btn-danger w-100 mb-2" onclick="rejectHomestay(@Model.Homestay.Id)">
                                    <i class="fas fa-times me-2"></i>Từ chối
                                </button>
                            }
                            else if(Model.Homestay.IsApproved)
                            {
                                @if(Model.Homestay.IsActive)
                                {
                                    <button type="button" class="btn btn-warning w-100 mb-2" onclick="deactivateHomestay(@Model.Homestay.Id)">
                                        <i class="fas fa-ban me-2"></i>Vô hiệu hóa
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-success w-100 mb-2" onclick="activateHomestay(@Model.Homestay.Id)">
                                        <i class="fas fa-play me-2"></i>Kích hoạt
                                    </button>
                                }
                            }

                            <a href="@Url.Action("Details", "Homestay", new { id = Model.Homestay.Id })" target="_blank" class="btn btn-outline-primary w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>Xem trang công khai
                            </a>

                            <a href="@Url.Action("UserDetail", new { id = Model.Homestay.HostId })" class="btn btn-outline-info w-100 mb-2">
                                <i class="fas fa-user me-2"></i>Xem thông tin chủ nhà
                            </a>

                            <a href="@Url.Action("Bookings", new { search = Model.Homestay.Name })" class="btn btn-outline-success w-100">
                                <i class="fas fa-calendar-check me-2"></i>Xem đặt phòng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function approveHomestay(id) {
            if (confirm('Bạn có chắc chắn muốn phê duyệt homestay này?')) {
                $.post('@Url.Action("ApproveHomestay")', { id: id }, function(data) {
                    if (data.success !== false) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                });
            }
        }

        function rejectHomestay(id) {
            if (confirm('Bạn có chắc chắn muốn từ chối homestay này?')) {
                $.post('@Url.Action("RejectHomestay")', { id: id }, function(data) {
                    if (data.success !== false) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                });
            }
        }

        function activateHomestay(id) {
            if (confirm('Bạn có chắc chắn muốn kích hoạt homestay này?')) {
                $.post('@Url.Action("ActivateHomestay")', { id: id }, function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                });
            }
        }

        function deactivateHomestay(id) {
            if (confirm('Bạn có chắc chắn muốn vô hiệu hóa homestay này?')) {
                $.post('@Url.Action("DeactivateHomestay")', { id: id }, function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                });
            }
        }
    </script>
}

