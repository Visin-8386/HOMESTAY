@{
    ViewData["Title"] = "Test Booking Address Input";
    Layout = "_Layout_New";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-map-marker-alt me-2"></i>Test Booking Address Input</h2>
                <a href="@Url.Action("Index", "Booking")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>

            <div class="alert alert-info">
                <h5><i class="fas fa-info-circle me-2"></i>Về tính năng này</h5>
                <p class="mb-2">
                    Đây là trang test cho chức năng nhập địa chỉ trong booking system với các tính năng:
                </p>
                <ul class="mb-0">
                    <li>🔍 <strong>Auto-geocoding:</strong> Tự động tìm tọa độ từ địa chỉ</li>
                    <li>📍 <strong>Fallback search:</strong> Tìm khu vực gần nhất khi không tìm thấy địa chỉ chính xác</li>
                    <li>🗺️ <strong>Interactive map:</strong> Click và kéo thả để điều chỉnh vị trí</li>
                    <li>📍 <strong>GPS location:</strong> Sử dụng vị trí hiện tại</li>
                    <li>✅ <strong>Smart validation:</strong> Kiểm tra và đề xuất địa chỉ</li>
                </ul>
            </div>

            <!-- Test Address Input Form -->
            <div class="card shadow">
                <div class="card-body">
                    <form id="testAddressForm">
                        @await Html.PartialAsync("_BookingAddressInput")
                        
                        <!-- Test Actions -->
                        <div class="mt-4 border-top pt-4">
                            <h5 class="text-primary">🧪 Test Actions</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <button type="button" class="btn btn-success w-100 mb-2" id="saveAddressBtn">
                                        <i class="fas fa-save me-2"></i>Lưu địa chỉ (Test API)
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <button type="button" class="btn btn-info w-100 mb-2" id="validateAddressBtn">
                                        <i class="fas fa-check-circle me-2"></i>Validate địa chỉ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Test Results -->
            <div class="card mt-4" id="testResults" style="display: none;">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-flask me-2"></i>Test Results</h5>
                </div>
                <div class="card-body">
                    <div id="testResultsContent">
                        <!-- Test results will be displayed here -->
                    </div>
                </div>
            </div>

            <!-- Address Data Preview -->
            <div class="card mt-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-code me-2"></i>Live Address Data Preview</h5>
                </div>
                <div class="card-body">
                    <pre id="addressDataPreview" class="bg-light p-3 border rounded">
{
  "message": "Nhập địa chỉ để xem dữ liệu real-time..."
}
                    </pre>
                </div>
            </div>

            <!-- Quick Test Addresses -->
            <div class="card mt-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-rocket me-2"></i>Quick Test Addresses</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Click để test nhanh với các địa chỉ homestay thật:</p>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-sm w-100" 
                                    onclick="testQuickAddress('123 Phạm Ngũ Lão, Quận 1, TP.HCM')">
                                🏙️ TP.HCM - Phạm Ngũ Lão
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-sm w-100" 
                                    onclick="testQuickAddress('45 Hàng Bạc, Hoàn Kiếm, Hà Nội')">
                                🏛️ Hà Nội - Hàng Bạc
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-sm w-100" 
                                    onclick="testQuickAddress('Trần Phú, Nha Trang, Khánh Hòa')">
                                🏖️ Nha Trang - Trần Phú
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-sm w-100" 
                                    onclick="testQuickAddress('Phố cổ Hội An, Quảng Nam')">
                                🏮 Hội An - Phố cổ
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-sm w-100" 
                                    onclick="testQuickAddress('Đường Nguyễn Du, Đà Lạt, Lâm Đồng')">
                                🌸 Đà Lạt - Nguyễn Du
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-sm w-100" 
                                    onclick="testQuickAddress('Bãi Sao, Phú Quốc, Kiên Giang')">
                                🏝️ Phú Quốc - Bãi Sao
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Test functions
function testQuickAddress(address) {
    console.log('🧪 Testing quick address:', address);
    
    // Fill the full address search field
    document.getElementById('fullAddressSearch').value = address;
    
    // Trigger the search
    if (window.bookingAddressManager) {
        bookingAddressManager.searchAddressOnMap();
        
        // Show success message
        showTestResult('info', `🔍 Đang test địa chỉ: ${address}`);
    } else {
        showTestResult('error', '❌ Address manager chưa được khởi tạo');
    }
}

function showTestResult(type, message, data = null) {
    const resultsDiv = document.getElementById('testResults');
    const contentDiv = document.getElementById('testResultsContent');
    
    let alertClass = 'alert-info';
    let icon = 'fas fa-info-circle';
    
    switch(type) {
        case 'success':
            alertClass = 'alert-success';
            icon = 'fas fa-check-circle';
            break;
        case 'error':
            alertClass = 'alert-danger';
            icon = 'fas fa-exclamation-circle';
            break;
        case 'warning':
            alertClass = 'alert-warning';
            icon = 'fas fa-exclamation-triangle';
            break;
    }
    
    let content = `
        <div class="alert ${alertClass}">
            <i class="${icon} me-2"></i>${message}
        </div>
    `;
    
    if (data) {
        content += `
            <div class="mt-3">
                <h6>📊 Data:</h6>
                <pre class="bg-light p-3 border rounded">${JSON.stringify(data, null, 2)}</pre>
            </div>
        `;
    }
    
    contentDiv.innerHTML = content;
    resultsDiv.style.display = 'block';
    
    // Auto-hide after 10 seconds for info messages
    if (type === 'info') {
        setTimeout(() => {
            resultsDiv.style.display = 'none';
        }, 10000);
    }
}

// Real-time address data preview
function updateAddressPreview() {
    if (window.getBookingAddressData) {
        const addressData = getBookingAddressData();
        const preview = document.getElementById('addressDataPreview');
        
        if (addressData && (addressData.streetName || addressData.fullAddress)) {
            preview.textContent = JSON.stringify({
                timestamp: new Date().toISOString(),
                fullAddress: addressData.fullAddress || 'Đang xây dựng...',
                components: {
                    houseNumber: addressData.houseNumber || null,
                    streetName: addressData.streetName || null,
                    ward: addressData.ward || null,
                    district: addressData.district || null,
                    city: addressData.city || null
                },
                coordinates: {
                    latitude: addressData.latitude || null,
                    longitude: addressData.longitude || null,
                    hasCoordinates: !!(addressData.latitude && addressData.longitude)
                },
                validation: {
                    hasMinimumInfo: !!(addressData.streetName),
                    hasCoordinates: !!(addressData.latitude && addressData.longitude),
                    isComplete: !!(addressData.streetName && addressData.latitude && addressData.longitude)
                }
            }, null, 2);
        } else {
            preview.textContent = JSON.stringify({
                message: "Chưa có dữ liệu địa chỉ...",
                timestamp: new Date().toISOString()
            }, null, 2);
        }
    }
}

// Event handlers
document.addEventListener('DOMContentLoaded', function() {
    console.log('🧪 Booking Address Test Page loaded');
    
    // Save address button
    document.getElementById('saveAddressBtn').addEventListener('click', async function() {
        if (!window.getBookingAddressData) {
            showTestResult('error', '❌ Address manager không khả dụng');
            return;
        }
        
        const addressData = getBookingAddressData();
        
        if (!addressData || !addressData.streetName) {
            showTestResult('warning', '⚠️ Vui lòng nhập ít nhất tên đường trước khi lưu');
            return;
        }
        
        try {
            showTestResult('info', '💾 Đang lưu địa chỉ...');
            
            const response = await fetch('@Url.Action("SaveBookingAddress", "Booking")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify(addressData)
            });
            
            const result = await response.json();
            
            if (result.success) {
                showTestResult('success', result.message, result.data);
            } else {
                showTestResult('error', result.message);
            }
            
        } catch (error) {
            console.error('Save address error:', error);
            showTestResult('error', '❌ Lỗi khi lưu địa chỉ: ' + error.message);
        }
    });
    
    // Validate address button
    document.getElementById('validateAddressBtn').addEventListener('click', function() {
        if (!window.getBookingAddressData) {
            showTestResult('error', '❌ Address manager không khả dụng');
            return;
        }
        
        const addressData = getBookingAddressData();
        
        const validation = {
            hasStreetName: !!(addressData && addressData.streetName),
            hasCoordinates: !!(addressData && addressData.latitude && addressData.longitude),
            hasCompleteAddress: !!(addressData && addressData.streetName && addressData.ward && addressData.district && addressData.city),
            isValid: false
        };
        
        validation.isValid = validation.hasStreetName && validation.hasCoordinates;
        
        const messages = [];
        if (!validation.hasStreetName) messages.push('❌ Thiếu tên đường');
        if (!validation.hasCoordinates) messages.push('❌ Thiếu tọa độ');
        if (!validation.hasCompleteAddress) messages.push('⚠️ Địa chỉ chưa đầy đủ');
        
        if (validation.isValid) {
            messages.push('✅ Địa chỉ hợp lệ');
            showTestResult('success', messages.join('<br>'), {
                addressData,
                validation
            });
        } else {
            showTestResult('warning', messages.join('<br>'), {
                addressData,
                validation
            });
        }
    });
    
    // Real-time preview updates
    setInterval(updateAddressPreview, 2000); // Update every 2 seconds
    updateAddressPreview(); // Initial update
});
</script>
}

