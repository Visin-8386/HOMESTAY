@model WebHS.Models.User

<div class="alert alert-warning mb-0 text-center border-0 rounded-0" role="alert" 
     style="position: fixed; top: 56px; left: 0; right: 0; z-index: 1040;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Email chưa được xác minh!</strong> 
                Vui lòng kiểm tra hộp thư và xác minh email để sử dụng đầy đủ tính năng.
            </div>
            <div class="col-md-4 text-md-end mt-2 mt-md-0">
                <a href="@Url.Action("ResendConfirmationEmail", "Account", new { email = Model.Email })" 
                   class="btn btn-sm btn-outline-warning me-2">
                    <i class="fas fa-redo me-1"></i>Gửi lại
                </a>
                <a href="@Url.Action("CheckYourEmail", "Account")" class="btn btn-sm btn-warning">
                    <i class="fas fa-envelope me-1"></i>Xem hướng dẫn
                </a>
                <button type="button" class="btn btn-sm btn-outline-secondary ms-2" 
                        onclick="hideEmailNotification()" aria-label="Đóng">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function hideEmailNotification() {
    document.querySelector('.alert-warning').style.display = 'none';
    // Adjust main content margin
    const main = document.querySelector('main');
    if (main) {
        main.style.marginTop = '70px';
    }
    // Store in session storage so it doesn't show again in this session
    sessionStorage.setItem('hideEmailNotification', 'true');
}

// Check if notification was hidden in this session
if (sessionStorage.getItem('hideEmailNotification') === 'true') {
    document.addEventListener('DOMContentLoaded', function() {
        hideEmailNotification();
    });
}
</script>

