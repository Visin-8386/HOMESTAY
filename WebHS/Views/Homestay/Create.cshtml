            // Real-time form validation
            $('form').on('submit', function(e) {
                var isValid = true;
                var errorMessages = [];

                // Validate required fields
                $('input[required], textarea[required], select[required]').each(function() {
                    if (!$(this).val() || $(this).val().trim() === '') {
                        isValid = false;
                        $(this).addClass('is-invalid');
                        errorMessages.push('Vui lòng điền đầy đủ thông tin bắt buộc');
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                // Validate price
                var price = parseInt($('#PricePerNight').val());
                if (price < 50000) {
                    isValid = false;
                    $('#PricePerNight').addClass('is-invalid');
                    errorMessages.push('Giá phòng phải từ 50,000 VND trở lên');
                }

                // Validate guests capacity
                var maxGuests = parseInt($('#MaxGuests').val());
                if (maxGuests < 1 || maxGuests > 20) {
                    isValid = false;
                    $('#MaxGuests').addClass('is-invalid');
                    errorMessages.push('Số lượng khách phải từ 1 đến 20 người');
                }

                // Validate coordinates
                var lat = parseFloat($('#Latitude').val());
                var lng = parseFloat($('#Longitude').val());
                if (isNaN(lat) || isNaN(lng) || lat < -90 || lat > 90 || lng < -180 || lng > 180) {
                    isValid = false;
                    errorMessages.push('Tọa độ không hợp lệ. Vui lòng kiểm tra lại địa chỉ');
                }

                if (!isValid) {
                    e.preventDefault();
                    alert(errorMessages.join('\n'));
                    return false;
                }

                // Show loading state
                $(this).find('button[type="submit"]').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang tạo...');
            });
            
