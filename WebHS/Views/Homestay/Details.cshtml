        // Generate mock weather for selected date
        function generateMockWeatherForDate(dateStr) {
            const loadingEl = document.getElementById('selectedDateWeatherLoading');
            const contentEl = document.getElementById('selectedDateWeatherContent');
            
            if (loadingEl) loadingEl.style.display = 'none';
            
            // Generate predictable but varied mock data based on date
            const date = new Date(dateStr);
            const dayOfYear = Math.floor((date - new Date(date.getFullYear(), 0, 0)) / (1000 * 60 * 60 * 24));
            const seed = dayOfYear + date.getFullYear();
            
            // Simple pseudo-random based on date
            const pseudo = ((seed * 9301 + 49297) % 233280) / 233280;
            const temp = Math.round(23 + pseudo * 8); // 23-31°C
            const humidity = Math.round(60 + pseudo * 30); // 60-90%
            const windSpeed = Math.round((1 + pseudo * 4) * 10) / 10; // 1-5 m/s
            
            const descriptions = ['Trời nắng đẹp', 'Có mây nhẹ', 'Nắng ít mây', 'Trời quang đãng', 'Mây rải rác'];
            const icons = ['01d', '02d', '03d', '04d'];
            
            const description = descriptions[Math.floor(pseudo * descriptions.length)];
            const icon = icons[Math.floor(pseudo * icons.length)];
            
            // Update display
            const weatherIcon = document.getElementById('selectedDateWeatherIcon');
            const weatherTemp = document.getElementById('selectedDateWeatherTemp');
            const weatherDesc = document.getElementById('selectedDateWeatherDesc');
            const weatherHumidity = document.getElementById('selectedDateWeatherHumidity');
            const weatherWind = document.getElementById('selectedDateWeatherWind');
            
            if (weatherIcon) weatherIcon.src = 'https://openweathermap.org/img/wn/' + icon + '@@2x.png';
            if (weatherTemp) weatherTemp.textContent = temp + '°C';
            if (weatherDesc) weatherDesc.textContent = description;
            if (weatherHumidity) weatherHumidity.textContent = humidity + '%';
            if (weatherWind) weatherWind.textContent = windSpeed + ' m/s';
            
            if (contentEl) contentEl.style.display = 'block';
            console.log('✅ Mock weather generated for selected date:', dateStr);
        }
