        // Promotion handling
        let availablePromotions = [];        // Load available promotions
        function loadPromotions() {
            const homestayId = @Model.Homestay.Id;
            
            // Convert to Date objects if they are strings
            let checkIn, checkOut;
            if (selectedCheckIn) {
                checkIn = typeof selectedCheckIn === 'string' ? new Date(selectedCheckIn) : selectedCheckIn;
            } else {
                checkIn = new Date();
            }
            
            if (selectedCheckOut) {
                checkOut = typeof selectedCheckOut === 'string' ? new Date(selectedCheckOut) : selectedCheckOut;
            } else {
                checkOut = new Date(Date.now() + 86400000); // +1 day
            }
            
            fetch(`/Homestay/GetAvailablePromotions?homestayId=${homestayId}&checkIn=${checkIn.toISOString()}&checkOut=${checkOut.toISOString()}`)
                .then(response => response.json())
                .then(data => {
                    if (data.error) {
                        console.error('Error loading promotions:', data.error);
                        return;
                    }
                    
                    availablePromotions = data;
                    populatePromotionDropdown();
                })
                .catch(error => {
                    console.error('Error loading promotions:', error);
                });
        }
        
        // Populate promotion dropdown
        function populatePromotionDropdown() {
            const select = document.getElementById('promotionSelect');
            select.innerHTML = '<option value="">Chọn khuyến mãi</option>';
            
            availablePromotions.forEach(promo => {
                const option = document.createElement('option');
                option.value = promo.code;
                option.textContent = `${promo.name} - ${formatPromotionValue(promo)}`;
                option.dataset.description = promo.description;
                option.dataset.type = promo.type;
                option.dataset.value = promo.value;
                option.dataset.minAmount = promo.minAmount;
                option.dataset.maxDiscount = promo.maxDiscount;
                select.appendChild(option);
            });
        }
        
        // Format promotion value for display
        function formatPromotionValue(promo) {
            if (promo.type === 'Percentage') {
                return `Giảm ${promo.value}%`;
            } else {
                return `Giảm ${promo.value.toLocaleString('vi-VN')}đ`;
            }
        }
        
