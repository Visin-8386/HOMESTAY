        });
        
        function showPromotionDetails(option) {
            const details = document.getElementById('promotionDetails');
            const description = document.getElementById('promotionDescription');
            
            let detailText = option.dataset.description || option.textContent;
            if (option.dataset.minAmount) {
                detailText += ` (Áp dụng cho đơn hàng từ ${parseFloat(option.dataset.minAmount).toLocaleString('vi-VN')}đ)`;
            }
            if (option.dataset.maxDiscount) {
                detailText += ` (Tối đa ${parseFloat(option.dataset.maxDiscount).toLocaleString('vi-VN')}đ)`;
            }
            
            description.textContent = detailText;
            details.style.display = 'block';
        }
        
        function hidePromotionDetails() {
            document.getElementById('promotionDetails').style.display = 'none';
        }
        
        // Handle apply promotion button
        document.getElementById('applyPromotion').addEventListener('click', function() {
            const select = document.getElementById('promotionSelect');
            const manualInput = document.getElementById('promotionCode');
            let promotionCode = '';
            
            if (select.style.display !== 'none' && select.value) {
                promotionCode = select.value;
            } else if (manualInput.style.display !== 'none' && manualInput.value) {
                promotionCode = manualInput.value.trim();
            }
            
            if (promotionCode) {
                validateAndApplyPromotion(promotionCode);
            } else {
                showPromotionFeedback('Vui lòng chọn hoặc nhập mã khuyến mãi', 'error');
            }
        });
        
        // Validate and apply promotion
        function validateAndApplyPromotion(code) {
            // Check if it's from the dropdown
            const promo = availablePromotions.find(p => p.code === code);
            if (promo) {
                showPromotionFeedback(`Áp dụng thành công: ${promo.name}`, 'success');
                calculatePriceWithPromotion(code);
                return;
            }
            
            // If not in dropdown, validate via API
            if (!selectedCheckIn || !selectedCheckOut) {
                showPromotionFeedback('Vui lòng chọn ngày nhận và trả phòng trước', 'error');
                return;
            }
            
            const homestayId = @Model.Homestay.Id;
            const checkIn = selectedCheckIn;
            const checkOut = selectedCheckOut;
              fetch(`/Homestay/CalculatePrice?homestayId=${homestayId}&checkIn=${checkIn}&checkOut=${checkOut}&promotionCode=${encodeURIComponent(code)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.promotionApplied) {
                        showPromotionFeedback(`Áp dụng thành công! Giảm ${data.discountAmount.toLocaleString('vi-VN')} đ`, 'success');
                        updatePriceDisplay(data);
                    } else {
                        showPromotionFeedback(data.message || 'Mã khuyến mãi không hợp lệ', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error validating promotion:', error);
                    showPromotionFeedback('Có lỗi xảy ra khi kiểm tra mã khuyến mãi', 'error');
                });
        }
        
        // Calculate price with promotion (for dropdown selections)
        function calculatePriceWithPromotion(code) {
            if (!selectedCheckIn || !selectedCheckOut) {
                showPromotionFeedback('Vui lòng chọn ngày nhận và trả phòng trước', 'error');
                return;
            }
            
            calculatePrice(); // This will include the promotion code
        }
        
        // Show promotion feedback
        function showPromotionFeedback(message, type) {
            const feedback = document.getElementById('promotionFeedback');
            feedback.textContent = message;
            feedback.className = `form-text ${type === 'success' ? 'text-success' : 'text-danger'}`;
        }
        
        // Update price display
        function updatePriceDisplay(data) {
            if (data.numberOfNights) {
                document.getElementById('numberOfNights').textContent = data.numberOfNights;
            }
            if (data.subTotal) {
                document.getElementById('subTotal').textContent = data.subTotal.toLocaleString('vi-VN') + ' VNĐ';
            }
            if (data.discountAmount && data.discountAmount > 0) {
                document.getElementById('discount').textContent = '-' + data.discountAmount.toLocaleString('vi-VN') + ' VNĐ';
                document.getElementById('discountRow').style.display = 'flex';
            } else {
                document.getElementById('discountRow').style.display = 'none';
            }            if (data.totalAmount) {
                document.getElementById('totalPrice').textContent = data.totalAmount.toLocaleString('vi-VN') + ' VNĐ';
            }
        }
    </script>
}

