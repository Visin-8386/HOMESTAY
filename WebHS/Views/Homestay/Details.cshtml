        // Calculate price based on selected dates
        function calculatePrice() {
            const checkInInput = document.getElementById('checkInDate');
            const checkOutInput = document.getElementById('checkOutDate');
            const numberOfNightsEl = document.getElementById('numberOfNights');
            const subTotalEl = document.getElementById('subTotal');
            const totalPriceEl = document.getElementById('totalPrice');
            
            if (!checkInInput?.value || !checkOutInput?.value) {
                // Reset price display if dates are not selected
                if (numberOfNightsEl) numberOfNightsEl.textContent = '0';
                if (subTotalEl) subTotalEl.textContent = '0 VNĐ';
                if (totalPriceEl) totalPriceEl.textContent = '0 VNĐ';
                return;
            }
            
            const checkInDate = new Date(checkInInput.value);
            const checkOutDate = new Date(checkOutInput.value);
            
            if (checkOutDate <= checkInDate) {
                // Invalid date range
                if (numberOfNightsEl) numberOfNightsEl.textContent = '0';
                if (subTotalEl) subTotalEl.textContent = '0 VNĐ';
                if (totalPriceEl) totalPriceEl.textContent = '0 VNĐ';
                return;
            }
            
            // Get promotion code if any
            const select = document.getElementById('promotionSelect');
            const manualInput = document.getElementById('promotionCode');
            let promotionCode = '';
            
            if (select.style.display !== 'none' && select.value) {
                promotionCode = select.value;
            } else if (manualInput.style.display !== 'none' && manualInput.value) {
                promotionCode = manualInput.value.trim();
            }
            
            // Call API to calculate price with promotion
            const homestayId = @Model.Homestay.Id;
            const checkIn = checkInInput.value;
            const checkOut = checkOutInput.value;
            
            let url = `/Homestay/CalculatePrice?homestayId=${homestayId}&checkIn=${checkIn}&checkOut=${checkOut}`;
            if (promotionCode) {
                url += `&promotionCode=${encodeURIComponent(promotionCode)}`;
            }
            
            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        updatePriceDisplay(data);
                    } else {
                        // Fallback to basic calculation
                        const numberOfNights = Math.floor((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));
                        const pricePerNight = @Model.Homestay.PricePerNight.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        const subTotal = numberOfNights * pricePerNight;
                        
                        if (numberOfNightsEl) numberOfNightsEl.textContent = numberOfNights.toString();
                        if (subTotalEl) subTotalEl.textContent = subTotal.toLocaleString('vi-VN') + ' VNĐ';
                        if (totalPriceEl) totalPriceEl.textContent = subTotal.toLocaleString('vi-VN') + ' VNĐ';
                    }
                })
                .catch(error => {
                    console.error('Error calculating price:', error);
                    // Fallback to basic calculation
                    const numberOfNights = Math.floor((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));
                    const pricePerNight = @Model.Homestay.PricePerNight.ToString(System.Globalization.CultureInfo.InvariantCulture);
                    const subTotal = numberOfNights * pricePerNight;
                    
                    if (numberOfNightsEl) numberOfNightsEl.textContent = numberOfNights.toString();
                    if (subTotalEl) subTotalEl.textContent = subTotal.toLocaleString('vi-VN') + ' VNĐ';
                    if (totalPriceEl) totalPriceEl.textContent = subTotal.toLocaleString('vi-VN') + ' VNĐ';
                });
            
            console.log('💰 Price calculation initiated:', {
                checkIn: checkInInput.value,
                checkOut: checkOutInput.value,
                promotionCode
            });
        }

