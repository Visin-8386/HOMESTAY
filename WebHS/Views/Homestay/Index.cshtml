@using WebHSPromotionType = WebHS.Models.PromotionType
@model WebHS.ViewModels.HomestayListViewModel
@* Updated model binding *@
@{
    ViewData["Title"] = "Danh sách Homestay";
}

<div class="container-fluid">    <!-- Search Section -->
    <div class="search-section py-5 mb-4">
        <div class="container">            <div class="text-center mb-4">
                <h1 class="display-4 fw-bold mb-2">
                    <i class="fas fa-home me-3"></i>Tìm Homestay Hoàn Hảo
                </h1>
                <p class="lead">
                    <i class="fas fa-map-marked-alt me-2"></i>Khám phá những không gian nghỉ dưỡng tuyệt vời nhất
                </p>
            </div>
            <form asp-action="Index" method="get" class="row g-3">                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-map-marker-alt me-2"></i>Địa điểm
                    </label>
                    <input asp-for="SearchModel.Location" class="form-control" placeholder="Nhập thành phố, tỉnh...">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-calendar-check me-2"></i>Ngày nhận
                    </label>
                    <input asp-for="SearchModel.CheckInDate" type="date" class="form-control">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-calendar-times me-2"></i>Ngày trả
                    </label>
                    <input asp-for="SearchModel.CheckOutDate" type="date" class="form-control">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-users me-2"></i>Số khách
                    </label>
                    <select asp-for="SearchModel.NumberOfGuests" class="form-select">
                        <option value="1">1 khách</option>
                        <option value="2">2 khách</option>
                        <option value="3">3 khách</option>
                        <option value="4">4 khách</option>
                        <option value="5">5+ khách</option>
                    </select>
                </div>                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search me-2"></i>Tìm kiếm
                    </button>                    <button type="button" class="btn btn-outline-light filter-btn" data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                        <i class="fas fa-filter me-2"></i>Bộ lọc
                    </button>
                </div>
            </form>

            <!-- Advanced Filters -->
            <div class="collapse mt-4" id="advancedFilters">
                <div class="card advanced-filters border-0 shadow-lg">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="fas fa-sliders-h me-2"></i>Bộ lọc nâng cao
                        </h5>                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">
                                    <i class="fas fa-dollar-sign me-2"></i>Giá từ
                                </label>
                                <input asp-for="SearchModel.MinPrice" type="number" class="form-control" placeholder="0">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">
                                    <i class="fas fa-money-bill-wave me-2"></i>Giá đến
                                </label>
                                <input asp-for="SearchModel.MaxPrice" type="number" class="form-control" placeholder="5,000,000">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">
                                    <i class="fas fa-building me-2"></i>Loại nhà
                                </label>
                                <select asp-for="SearchModel.HomestayType" class="form-select">
                                    <option value="">Tất cả</option>
                                    <option value="House">🏠 Nhà riêng</option>
                                    <option value="Apartment">🏢 Căn hộ</option>
                                    <option value="Villa">🏰 Biệt thự</option>
                                    <option value="Bungalow">🏖️ Bungalow</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">
                                    <i class="fas fa-sort me-2"></i>Sắp xếp
                                </label>
                                <select asp-for="SearchModel.SortBy" class="form-select">
                                    <option value="price_asc">💰 Giá thấp đến cao</option>
                                    <option value="price_desc">💎 Giá cao đến thấp</option>
                                    <option value="rating">⭐ Đánh giá cao nhất</option>
                                    <option value="newest">🆕 Mới nhất</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>        </div>
    </div>

    <!-- Features & Stats Section -->
    <div class="features-section py-5">
        <div class="container">
            <!-- Stats Cards -->
            <div class="row mb-5">
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="stat-card text-center">
                        <div class="stat-icon">
                            <i class="fas fa-home"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-number" data-target="@Model.TotalCount">0</h3>
                            <p class="stat-label">Homestay Chất Lượng</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="stat-card text-center">
                        <div class="stat-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-number" data-target="15000">0</h3>
                            <p class="stat-label">Khách Hàng Hài Lòng</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="stat-card text-center">
                        <div class="stat-icon">
                            <i class="fas fa-star"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-number" data-target="98">0</h3>
                            <p class="stat-label">% Đánh Giá Tích Cực</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="stat-card text-center">
                        <div class="stat-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-number" data-target="24">0</h3>
                            <p class="stat-label">Giờ Hỗ Trợ</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Features Highlight -->
            <div class="row align-items-center mb-5">
                <div class="col-lg-6">
                    <div class="feature-content">
                        <h2 class="feature-title">
                            <i class="fas fa-gem me-3"></i>Tại Sao Chọn Chúng Tôi?
                        </h2>
                        <div class="feature-list">
                            <div class="feature-item">
                                <div class="feature-icon">
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                                <div class="feature-text">
                                    <h5>Đảm Bảo An Toàn</h5>
                                    <p>Tất cả homestay được kiểm duyệt kỹ lưỡng để đảm bảo chất lượng</p>
                                </div>
                            </div>
                            <div class="feature-item">
                                <div class="feature-icon">
                                    <i class="fas fa-money-bill-wave"></i>
                                </div>
                                <div class="feature-text">
                                    <h5>Giá Tốt Nhất</h5>
                                    <p>Cam kết giá tốt nhất thị trường với nhiều ưu đãi hấp dẫn</p>
                                </div>
                            </div>
                            <div class="feature-item">
                                <div class="feature-icon">
                                    <i class="fas fa-headset"></i>
                                </div>
                                <div class="feature-text">
                                    <h5>Hỗ Trợ 24/7</h5>
                                    <p>Đội ngũ chăm sóc khách hàng sẵn sàng hỗ trợ bạn mọi lúc</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="feature-animation">
                        <div class="floating-elements">
                            <div class="floating-card card-1">
                                <i class="fas fa-heart"></i>
                                <span>Yêu thích</span>
                            </div>
                            <div class="floating-card card-2">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>Địa điểm đẹp</span>
                            </div>
                            <div class="floating-card card-3">
                                <i class="fas fa-wifi"></i>
                                <span>WiFi miễn phí</span>
                            </div>
                            <div class="floating-card card-4">
                                <i class="fas fa-coffee"></i>
                                <span>Tiện nghi</span>
                            </div>
                            <div class="floating-card card-5">
                                <i class="fas fa-camera"></i>
                                <span>View đẹp</span>
                            </div>
                        </div>
                        <div class="central-graphic">
                            <div class="house-icon">
                                <i class="fas fa-home"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Popular Destinations -->
            <div class="popular-destinations mb-5">
                <div class="text-center mb-4">
                    <h2 class="section-title">
                        <i class="fas fa-fire me-3"></i>Điểm Đến Phổ Biến
                    </h2>
                    <p class="section-subtitle">Khám phá những địa điểm du lịch được yêu thích nhất</p>
                </div>                <div class="row">
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="destination-card">
                            <div class="destination-image">
                                <img src="https://images.unsplash.com/photo-1555400820-4d5a5a8e3b3a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Hà Nội" onerror="this.src='data:image/svg+xml;base64,'">
                                <div class="destination-overlay">
                                    <h4>Hà Nội</h4>
                                    <p>125 homestay</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="destination-card">
                            <div class="destination-image">
                                <img src="https://images.unsplash.com/photo-1583417319070-4a69db38a482?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Hồ Chí Minh" onerror="this.src='data:image/svg+xml;base64,'">
                                <div class="destination-overlay">
                                    <h4>TP. Hồ Chí Minh</h4>
                                    <p>89 homestay</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="destination-card">
                            <div class="destination-image">
                                <img src="https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Đà Nẵng" onerror="this.src='data:image/svg+xml;base64,'">
                                <div class="destination-overlay">
                                    <h4>Đà Nẵng</h4>
                                    <p>67 homestay</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="destination-card">
                            <div class="destination-image">
                                <img src="https://images.unsplash.com/photo-1598974077733-84ca04f48b1c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Sa Pa" onerror="this.src='data:image/svg+xml;base64,'">
                                <div class="destination-overlay">
                                    <h4>Sa Pa</h4>
                                    <p>43 homestay</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="mb-0 page-title">
                @if (!string.IsNullOrEmpty(Model.SearchModel.Location))
                {
                    <span>Homestay tại @Model.SearchModel.Location</span>
                }
                else
                {
                    <span>Tất cả Homestay</span>
                }
                <small class="text-muted">(@Model.TotalCount kết quả)</small>
            </h2>
        </div>

        @if (Model.Homestays.Any())
        {
            <div class="row">
                @foreach (var homestay in Model.Homestays)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm border-0 homestay-card">
                            <div class="position-relative">
                                <img src="@(!string.IsNullOrEmpty(homestay.PrimaryImage) ? homestay.PrimaryImage : "/images/default-homestay.jpg")" 
                                     class="card-img-top" alt="@homestay.Name" style="height: 200px; object-fit: cover;">
                                <div class="position-absolute top-0 end-0 m-2">
                                    @if (homestay.AverageRating > 0)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-star"></i> @homestay.AverageRating.ToString("F1")
                                        </span>
                                    }
                                </div>                                <div class="position-absolute bottom-0 start-0 m-2">
                                    <span class="badge bg-primary">@homestay.HomestayType</span>
                                    @if (!string.IsNullOrEmpty(homestay.YouTubeVideoId))
                                    {
                                        <span class="badge bg-danger ms-1" title="Có video giới thiệu">
                                            <i class="fab fa-youtube"></i>
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@homestay.Name</h5>
                                <p class="card-text text-muted small mb-2">
                                    <i class="fas fa-map-marker-alt me-1"></i>@homestay.City, @homestay.State
                                </p>
                                <p class="card-text flex-grow-1">@homestay.Description</p>                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <div>
                                        <span class="h5 price-highlight mb-0">@homestay.PricePerNight.ToString("N0") VNĐ</span>
                                        <small class="text-muted">/đêm</small>
                                    </div>
                                    <a asp-action="Details" asp-route-id="@homestay.Id" class="btn btn-outline-primary">
                                        <i class="fas fa-eye me-2"></i>Xem chi tiết
                                    </a>
                                </div>
                                <div class="mt-2">
                                    <small class="text-muted">
                                        <i class="fas fa-users me-1"></i>@homestay.MaxGuests khách
                                        <i class="fas fa-bed ms-2 me-1"></i>@homestay.Bedrooms phòng ngủ
                                        <i class="fas fa-bath ms-2 me-1"></i>@homestay.Bathrooms phòng tắm
                                    </small>
                                </div>
                                <div class="mt-2">
                                    @if (homestay.IsBooked)
                                    {
                                        <span class="badge bg-danger mb-2">Đã đặt</span>
                                        @if (homestay.NextAvailableDate.HasValue)
                                        {
                                            <small class="d-block">Ngày trả phòng: @homestay.NextAvailableDate.Value.ToString("dd/MM/yyyy")</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-success mb-2">Còn trống</span>
                                    }
                                    
                                    @if (homestay.BookingPeriods.Any())
                                    {
                                        <div class="accordion accordion-flush" id="bookingPeriods-@homestay.Id">
                                            <div class="accordion-item border-0">
                                                <h2 class="accordion-header">
                                                    <button class="btn btn-sm btn-outline-secondary p-1" type="button" 
                                                            data-bs-toggle="collapse" data-bs-target="#collapseBookings-@homestay.Id">
                                                        Xem lịch đặt phòng
                                                    </button>
                                                </h2>
                                                <div id="collapseBookings-@homestay.Id" class="accordion-collapse collapse" 
                                                     data-bs-parent="#bookingPeriods-@homestay.Id">
                                                    <div class="accordion-body p-2">
                                                        <ul class="list-unstyled small">
                                                            @foreach (var period in homestay.BookingPeriods)
                                                            {
                                                                <li>@period.CheckInDate.ToString("dd/MM/yyyy") - @period.CheckOutDate.ToString("dd/MM/yyyy")</li>
                                                            }
                                                        </ul>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@((IDictionary<string, string>)Model.GetRouteData(Model.CurrentPage - 1))">
                                <span><i class="fas fa-chevron-left"></i></span>
                            </a>
                        </li>
                          @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-all-route-data="@((IDictionary<string, string>)Model.GetRouteData(i))">
                                    <span>@i</span>
                                </a>
                            </li>
                        }
                          <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@((IDictionary<string, string>)Model.GetRouteData(Model.CurrentPage + 1))">
                                <span><i class="fas fa-chevron-right"></i></span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }        else
        {
            <div class="text-center py-5 no-results">
                <i class="fas fa-search fa-4x text-muted mb-4"></i>
                <h4 class="display-6 mb-3">Không tìm thấy homestay nào</h4>
                <p class="text-muted lead mb-4">Thử thay đổi bộ lọc tìm kiếm của bạn</p>
                <a asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="fas fa-home me-2"></i>Xem tất cả homestay
                </a>
            </div>
        }
    </div>
</div>

<style>
/* Card Animations & Effects */
.homestay-card {
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    position: relative;
}

.homestay-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
    pointer-events: none;
}

.homestay-card:hover::before {
    opacity: 1;
}

.homestay-card:hover {
    transform: translateY(-15px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}

.homestay-card .card-img-top {
    transition: all 0.4s ease;
    border-radius: 20px 20px 0 0;
    position: relative;
    z-index: 2;
}

.homestay-card:hover .card-img-top {
    transform: scale(1.08);
}

/* Search Section Styling */
.search-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
    color: white;
    position: relative;
    overflow: hidden;
    min-height: 60vh;
    display: flex;
    align-items: center;
}

.search-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="20" r="3" fill="rgba(255,255,255,0.15)"/><circle cx="80" cy="80" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="40" cy="60" r="1.5" fill="rgba(255,255,255,0.2)"/><circle cx="10" cy="90" r="2.5" fill="rgba(255,255,255,0.08)"/><circle cx="90" cy="10" r="1" fill="rgba(255,255,255,0.12)"/></svg>');
    animation: float 25s infinite linear;
}

.search-section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.1) 0%, transparent 50%),
                radial-gradient(circle at 70% 30%, rgba(255,255,255,0.08) 0%, transparent 50%);
    animation: pulse 4s ease-in-out infinite alternate;
}

@@keyframes float {
    0% { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
}

@@keyframes pulse {
    0% { opacity: 0.3; }
    100% { opacity: 0.7; }
}

.search-section .container {
    position: relative;
    z-index: 3;
}

.search-section h1 {
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    animation: slideInDown 1s ease-out;
}

.search-section p.lead {
    animation: slideInUp 1s ease-out 0.3s both;
}

@@keyframes slideInDown {
    from {
        opacity: 0;
        transform: translateY(-50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@@keyframes slideInUp {
    from {
        opacity: 0;
        transform: translateY(50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Form Controls Styling */
.form-control, .form-select {
    border: none;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(10px);
}

.form-control:focus, .form-select:focus {
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    transform: translateY(-3px) scale(1.02);
    background: rgba(255,255,255,1);
}

.form-label {
    font-weight: 600;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    animation: fadeInLeft 0.8s ease-out;
}

@@keyframes fadeInLeft {
    from {
        opacity: 0;
        transform: translateX(-30px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

/* Button Styling */
.btn {
    border-radius: 15px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-weight: 600;
    position: relative;
    overflow: hidden;
}

.btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    background: rgba(255,255,255,0.3);
    border-radius: 50%;
    transition: all 0.6s ease;
    transform: translate(-50%, -50%);
}

.btn:hover::before {
    width: 300px;
    height: 300px;
}

.btn-primary {
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
    background-size: 300% 300%;
    border: none;
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    animation: gradientShift 3s ease infinite;
}

@@keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.btn-primary:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.6);
}

.filter-btn {
    border: 2px solid rgba(255,255,255,0.8);
    color: white;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    font-weight: 600;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
}

.filter-btn:hover {
    background: rgba(255,255,255,0.2);
    border-color: white;
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 8px 25px rgba(255,255,255,0.3);
    color: white;
}

.btn-outline-primary {
    border: 2px solid #667eea;
    color: #667eea;
    background: transparent;
    position: relative;
    overflow: hidden;
}

.btn-outline-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, #667eea, #764ba2);
    transition: left 0.5s ease;
    z-index: -1;
}

.btn-outline-primary:hover::before {
    left: 0;
}

.btn-outline-primary:hover {
    color: white;
    border-color: transparent;
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
}

/* Badge Styling */
.badge {
    border-radius: 20px;
    padding: 10px 15px;
    font-weight: 600;
    text-shadow: none;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
}

.badge::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(45deg, rgba(255,255,255,0.1), transparent, rgba(255,255,255,0.1));
    transform: rotate(45deg);
    transition: all 0.5s ease;
    opacity: 0;
}

.badge:hover::before {
    opacity: 1;
    animation: shimmer 1s ease-in-out;
}

@@keyframes shimmer {
    0% { transform: translateX(-100%) rotate(45deg); }
    100% { transform: translateX(100%) rotate(45deg); }
}

.badge.bg-warning {
    background: linear-gradient(45deg, #ffd700, #ffed4e, #fff59d) !important;
    color: #333 !important;
    box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
}

.badge.bg-primary {
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb) !important;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
}

.badge.bg-success {
    background: linear-gradient(45deg, #56ab2f, #a8e6cf, #88e5a3) !important;
    box-shadow: 0 4px 15px rgba(86, 171, 47, 0.3);
}

.badge.bg-danger {
    background: linear-gradient(45deg, #ff416c, #ff4b2b, #ff6b9d) !important;
    box-shadow: 0 4px 15px rgba(255, 65, 108, 0.3);
}

/* Title Animation */
.page-title {
    position: relative;
    display: inline-block;
    background: linear-gradient(45deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.page-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 0;
    height: 4px;
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
    border-radius: 2px;
    transition: width 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.page-title:hover::after {
    width: 100%;
}

/* Fade In Animation */
@@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.fade-in-up {
    animation: fadeInUp 0.8s ease forwards;
}

/* Stagger animation for cards */
.homestay-card:nth-child(1) { animation-delay: 0.1s; }
.homestay-card:nth-child(2) { animation-delay: 0.2s; }
.homestay-card:nth-child(3) { animation-delay: 0.3s; }
.homestay-card:nth-child(4) { animation-delay: 0.4s; }
.homestay-card:nth-child(5) { animation-delay: 0.5s; }
.homestay-card:nth-child(6) { animation-delay: 0.6s; }

/* Price highlighting */
.price-highlight {
    position: relative;
    font-weight: bold;
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: priceGlow 2s ease-in-out infinite;
    transition: all 0.3s ease;
}

@@keyframes priceGlow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

.price-highlight:hover {
    transform: scale(1.1);
    filter: drop-shadow(0 0 10px rgba(102, 126, 234, 0.5));
}

/* Advanced filters styling */
.advanced-filters {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    animation: slideInFromTop 0.5s ease-out;
}

@@keyframes slideInFromTop {
    from {
        opacity: 0;
        transform: translateY(-30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.advanced-filters .card-title {
    background: linear-gradient(45deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Loading animation for images */
.card-img-top {
    border-radius: 20px 20px 0 0;
}

.position-relative.loading::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(90deg, 
        rgba(240,240,240,0.8) 25%, 
        rgba(220,220,220,0.8) 50%, 
        rgba(240,240,240,0.8) 75%);
    background-size: 200% 100%;
    animation: loading 2s infinite;
    border-radius: 20px 20px 0 0;
    z-index: 2;
}

@@keyframes loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

/* Pagination styling */
.pagination .page-link {
    border-radius: 50%;
    margin: 0 8px;
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #667eea;
    color: #667eea;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: white;
    position: relative;
    overflow: hidden;
}

.pagination .page-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, #667eea, #764ba2);
    border-radius: 50%;
    transform: scale(0);
    transition: transform 0.3s ease;
}

.pagination .page-item.active .page-link::before,
.pagination .page-link:hover::before {
    transform: scale(1);
}

.pagination .page-item.active .page-link,
.pagination .page-link:hover {
    color: white;
    border-color: transparent;
    transform: scale(1.15);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
}

.pagination .page-link span {
    position: relative;
    z-index: 2;
}

/* Scroll reveal animation */
.scroll-reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
}

/* No results styling */
.no-results {
    padding: 80px 20px;
    text-align: center;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
    border-radius: 20px;
    position: relative;
    overflow: hidden;
}

.no-results::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
    animation: rotate 10s linear infinite;
}

@@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.no-results i {
    animation: bounce 2s infinite, colorChange 3s ease-in-out infinite;
}

@@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-30px); }
    60% { transform: translateY(-15px); }
}

@@keyframes colorChange {
    0%, 100% { color: #667eea; }
    50% { color: #764ba2; }
}

.no-results h4, .no-results p {
    position: relative;
    z-index: 2;
}

/* Card body effects */
.card-body {
    position: relative;
    z-index: 2;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(10px);
}

/* Enhanced icon effects */
.fas, .fab {
    transition: all 0.3s ease;
}

.card:hover .fas,
.card:hover .fab {
    transform: scale(1.1);
    filter: drop-shadow(0 0 5px rgba(102, 126, 234, 0.5));
}

/* Responsive improvements */
@@media (max-width: 768px) {
    .homestay-card {
        margin-bottom: 30px;
    }
    
    .search-section {
        padding: 30px 0;
        min-height: 50vh;
    }
    
    .btn {
        width: 100%;
        margin-bottom: 15px;
    }
    
    .pagination .page-link {
        width: 35px;
        height: 35px;
        margin: 0 3px;
    }
}

/* Additional sparkle effect */
@@keyframes sparkle {
    0%, 100% { opacity: 0; transform: scale(0); }
    50% { opacity: 1; transform: scale(1); }
}

.sparkle {
    position: absolute;
    background: rgba(255,255,255,0.8);
    border-radius: 50%;
    pointer-events: none;
    animation: sparkle 1.5s ease-in-out infinite;
}

/* Features & Stats Section */
.features-section {
    background: linear-gradient(135deg, #f8f9ff 0%, #e8f2ff 100%);
    position: relative;
    overflow: hidden;
}

.features-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="25" cy="25" r="1" fill="rgba(102, 126, 234, 0.1)"/><circle cx="75" cy="75" r="1.5" fill="rgba(118, 75, 162, 0.08)"/><circle cx="50" cy="10" r="0.8" fill="rgba(240, 147, 251, 0.06)"/></svg>');
    opacity: 0.5;
}

/* Stats Cards */
.stat-card {
    background: white;
    border-radius: 20px;
    padding: 30px 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(102, 126, 234, 0.1);
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
    transform: scaleX(0);
    transition: transform 0.6s ease;
}

.stat-card:hover::before {
    transform: scaleX(1);
}

.stat-card:hover {
    transform: translateY(-10px) scale(1.05);
    box-shadow: 0 20px 40px rgba(102, 126, 234, 0.2);
}

.stat-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    background: linear-gradient(45deg, #667eea, #764ba2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.stat-icon::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, transparent, rgba(255,255,255,0.2), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
}

.stat-card:hover .stat-icon::before {
    transform: translateX(100%);
}

.stat-icon i {
    font-size: 2rem;
    color: white;
    animation: iconPulse 2s ease-in-out infinite;
}

@@keyframes iconPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

.stat-number {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 10px;
    background: linear-gradient(45deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.stat-label {
    color: #666;
    font-weight: 600;
    margin: 0;
}

/* Features Content */
.feature-content {
    position: relative;
    z-index: 2;
}

.feature-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 30px;
    background: linear-gradient(45deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.feature-item {
    display: flex;
    align-items: flex-start;
    margin-bottom: 30px;
    padding: 20px;
    background: white;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.feature-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(45deg, #667eea, #764ba2);
    transform: scaleY(0);
    transition: transform 0.3s ease;
}

.feature-item:hover::before {
    transform: scaleY(1);
}

.feature-item:hover {
    transform: translateX(10px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.15);
}

.feature-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(45deg, #667eea, #764ba2);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20px;
    flex-shrink: 0;
}

.feature-icon i {
    font-size: 1.5rem;
    color: white;
}

.feature-text h5 {
    margin-bottom: 8px;
    color: #333;
    font-weight: 600;
}

.feature-text p {
    margin: 0;
    color: #666;
    line-height: 1.6;
}

/* Feature Animation */
.feature-animation {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.floating-elements {
    position: relative;
    width: 100%;
    height: 100%;
}

.floating-card {
    position: absolute;
    background: white;
    padding: 15px 20px;
    border-radius: 25px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    color: #333;
    animation: float 6s ease-in-out infinite;
    border: 2px solid rgba(102, 126, 234, 0.1);
}

.floating-card i {
    color: #667eea;
    font-size: 1.2rem;
}

.card-1 {
    top: 20%;
    left: 10%;
    animation-delay: 0s;
}

.card-2 {
    top: 10%;
    right: 20%;
    animation-delay: 1s;
}

.card-3 {
    bottom: 30%;
    left: 5%;
    animation-delay: 2s;
}

.card-4 {
    bottom: 20%;
    right: 10%;
    animation-delay: 3s;
}

.card-5 {
    top: 50%;
    right: 5%;
    animation-delay: 4s;
}

@@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    25% { transform: translateY(-20px) rotate(1deg); }
    50% { transform: translateY(0px) rotate(0deg); }
    75% { transform: translateY(-10px) rotate(-1deg); }
}

.central-graphic {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: centralPulse 3s ease-in-out infinite;
    box-shadow: 0 0 30px rgba(102, 126, 234, 0.3);
}

.central-graphic::before {
    content: '';
    position: absolute;
    top: -10px;
    left: -10px;
    right: -10px;
    bottom: -10px;
    border: 2px solid rgba(102, 126, 234, 0.3);
    border-radius: 50%;
    animation: rippleEffect 2s ease-out infinite;
}

@@keyframes centralPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.1); }
}

@@keyframes rippleEffect {
    0% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.5); }
}

.house-icon i {
    font-size: 3rem;
    color: white;
}

/* Popular Destinations */
.section-title {
    font-size: 2.5rem;
    font-weight: bold;
    background: linear-gradient(45deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.section-subtitle {
    color: #666;
    font-size: 1.1rem;
    margin-bottom: 0;
}

.destination-card {
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    height: 250px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.destination-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}

.destination-image {
    position: relative;
    height: 100%;
    overflow: hidden;
}

.destination-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
}

.destination-card:hover .destination-image img {
    transform: scale(1.1);
}

.destination-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    color: white;
    padding: 30px 20px;
    transform: translateY(20px);
    transition: transform 0.4s ease;
}

.destination-card:hover .destination-overlay {
    transform: translateY(0);
}

.destination-overlay h4 {
    margin-bottom: 5px;
    font-weight: bold;
    font-size: 1.3rem;
}

.destination-overlay p {
    margin: 0;
    opacity: 0.9;
}

/* Counter Animation */
@@keyframes countUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Enhanced Responsive Design */
@@media (max-width: 768px) {
    .homestay-card {
        margin-bottom: 30px;
    }
    
    .search-section {
        padding: 30px 0;
        min-height: 50vh;
    }
    
    .btn {
        width: 100%;
        margin-bottom: 15px;
    }
    
    .pagination .page-link {
        width: 35px;
        height: 35px;
        margin: 0 3px;
    }
    
    .stat-card {
        margin-bottom: 20px;
    }
    
    .feature-title {
        font-size: 2rem;
        text-align: center;
    }
    
    .feature-animation {
        height: 300px;
        margin-top: 30px;
    }
    
    .floating-card {
        padding: 10px 15px;
        font-size: 0.9rem;
    }
    
    .central-graphic {
        width: 80px;
        height: 80px;
    }
    
    .house-icon i {
        font-size: 2rem;
    }
    
    .section-title {
        font-size: 2rem;
    }
    
    .destination-card {
        height: 200px;
    }
}

@@media (max-width: 576px) {
    .stat-number {
        font-size: 2rem;
    }
    
    .stat-icon {
        width: 60px;
        height: 60px;
    }
    
    .stat-icon i {
        font-size: 1.5rem;
    }
    
    .feature-item {
        flex-direction: column;
        text-align: center;
    }
    
    .feature-icon {
        margin-right: 0;
        margin-bottom: 15px;
    }
    
